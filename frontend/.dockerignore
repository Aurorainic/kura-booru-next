# Files/dirs excluded from the Docker build context.
# They are not needed for `npm ci`, `npm run build`, or runtime.

# Local node_modules — Docker installs its own
node_modules/
dist/
.astro/

# Build artifacts / caches
*.log
npm-debug.log*
.npm/
.eslintcache
.prettiercache
.cache/

# Test artifacts
coverage/
.nyc_output/

# Editor / OS junk
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Local env / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# VCS
.git/
.gitignore
.gitattributes

# Docker meta
Dockerfile
.dockerignore

# Docs (not needed for the build)
README.md
CHANGELOG.md
LICENSE
docs/

# CI
.github/
.gitlab-ci.yml