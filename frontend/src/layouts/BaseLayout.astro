---
import ThemeToggle from "@/components/ThemeToggle.tsx";
import "../styles/globals.css";

const gitTag = import.meta.env.PUBLIC_GIT_TAG || "dev";
const repoUrl = import.meta.env.PUBLIC_REPO_URL || "https://gitea.lainns.xyz/lainsaka/kura-booru-next";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Kura Booru", description = "个人动漫插画收藏与展示平台" } = Astro.props;
const fullTitle = title === "Kura Booru" ? title : `${title} — Kura Booru`;

const isAdmin = Astro.locals.isAdmin ?? false;
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#7DD3C0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Inline script for theme detection (prevents flash) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('kura-theme-preference');
        let resolved;
        if (stored === 'light' || stored === 'dark') {
          resolved = stored;
        } else {
          resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(resolved);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-40 border-b border-[var(--border-color)] bg-[var(--bg-surface)]/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 group">
            <span class="gradient-text text-xl font-bold tracking-tight">Kura</span>
            <span class="text-[var(--text-muted)] text-xl font-light">Booru</span>
          </a>

          <!-- Nav links -->
          <div class="flex items-center gap-2">
            <a
              href="/search"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-color)] transition-colors duration-150"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              搜索
            </a>
            <a
              href="/tags"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-color)] transition-colors duration-150"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h13.5M5.25 8.25V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 20.25 18V8.25m-15 0V6a2.25 2.25 0 0 1 2.25-2.25h10.5A2.25 2.25 0 0 1 20.25 6v2.25m-15 0h13.5" />
              </svg>
              标签
            </a>
            <div class="w-px h-5 bg-[var(--border-color)]" />
            {isAdmin ? (
              <div class="flex items-center gap-2">
                <a
                  href="/admin/posts"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-[var(--accent)] hover:bg-[var(--border-color)] transition-colors duration-150"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                  </svg>
                  管理
                </a>
                <a
                  href="/admin/auto-rating"
                  class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--border-color)] transition-colors duration-150"
                  title="自动评级规则"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
                  </svg>
                </a>
                <a
                  href="/admin/import"
                  class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--accent)] hover:bg-[var(--border-color)] transition-colors duration-150"
                  title="导入图片"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                  </svg>
                </a>
                <a
                  href="/admin/password"
                  class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-color)] transition-colors duration-150"
                  title="修改密码"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                  </svg>
                </a>
                <button
                  id="logout-btn"
                  type="button"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-red-400 hover:bg-[var(--border-color)] transition-colors duration-150"
                >
                  退出
                </button>
              </div>
            ) : (
              <a
                href="/login"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--border-color)] transition-colors duration-150"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
                登录
              </a>
            )}
            <div class="w-px h-5 bg-[var(--border-color)]" />
            <ThemeToggle client:load />
          </div>
        </div>
      </div>
    </nav>

    {isAdmin && (
      <div class="bg-[var(--accent)]/10 border-b border-[var(--accent)]/20 text-[var(--accent)] text-center text-xs py-1">
        🔒 管理模式 — 可见所有评级内容
      </div>
    )}

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--border-color)] py-6 mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between text-sm text-[var(--text-muted)]">
          <span>
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="gradient-text font-medium hover:opacity-80 transition-opacity">Kura Booru (Next)</a>
            <span class="ml-2">{gitTag}</span>
          </span>
          <span>个人动漫插画收藏</span>
        </div>
      </div>
    </footer>
  </body>
</html>

<script>
  import { logout } from "@/lib/api";

  document.getElementById("logout-btn")?.addEventListener("click", async () => {
    try {
      await logout();
    } catch {
      // Cookie is cleared server-side anyway
    }
    window.location.href = "/";
  });
</script>