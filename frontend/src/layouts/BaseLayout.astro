---
import ThemeToggle from "@/components/ThemeToggle.tsx";
import "../styles/globals.css";

const gitTag = import.meta.env.PUBLIC_GIT_TAG || "dev";
const repoUrl = import.meta.env.PUBLIC_REPO_URL || "https://gitea.lainns.xyz/lainsaka/kura-booru-next";
const aiTagEnabled = process.env.ENABLE_AI_TAG_PROCESSING === "true";

interface Props {
  title?: string;
  description?: string;
}

const siteSettings = Astro.locals.siteSettings;
const siteTitle = siteSettings?.site_title || "Kura Booru";
const siteDescription = siteSettings?.site_description || "个人动漫插画收藏与展示平台";
const announcement = siteSettings?.announcement || "";
const headInject = siteSettings?.head_inject || "";

const { title, description } = Astro.props;
const displayTitle = title || siteTitle;
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const metaDescription = description || siteDescription;

const isAdmin = Astro.locals.isAdmin ?? false;

// Split site title: first word gets gradient, rest is muted
const titleParts = siteTitle.split(" ");
const gradientPart = titleParts[0];
const mutedPart = titleParts.slice(1).join(" ");
---

<!doctype html>
<html lang="zh-CN" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#7DD3C0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Inline script for theme detection (prevents flash) -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('kura-theme-preference');
        var resolved;
        if (stored === 'light' || stored === 'dark') {
          resolved = stored;
        } else {
          resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(resolved);
      })();
    </script>

    <!-- Head injection from site settings (e.g. analytics scripts) -->
    {headInject && <Fragment set:html={headInject} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="nav-glass sticky top-0 z-40 border-b border-[var(--border-color)]">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 group">
            <img src="/logo.svg" alt={siteTitle} class="h-8 w-8" />
            <span class="gradient-text text-xl font-bold" style="letter-spacing: -0.02em;">{gradientPart}</span>
            {mutedPart && <span class="text-[var(--text-muted)] text-xl font-light" style="letter-spacing: -0.02em;">{mutedPart}</span>}
          </a>

          <!-- Nav links (desktop) -->
          <div class="hidden md:flex items-center gap-2" id="nav-links">
            <a
              href="/search"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              搜索
            </a>
            <a
              href="/tags"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h13.5M5.25 8.25V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 20.25 18V8.25m-15 0V6a2.25 2.25 0 0 1 2.25-2.25h10.5A2.25 2.25 0 0 1 20.25 6v2.25m-15 0h13.5" />
              </svg>
              标签
            </a>
            <div class="w-px h-5 bg-[var(--border-color)]" />
            {isAdmin ? (
              <div class="relative" id="admin-menu-wrapper">
                <button
                  id="admin-menu-btn"
                  type="button"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--accent-color)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                  </svg>
                  管理
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 transition-transform duration-[var(--duration-fast)]" id="admin-menu-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                </button>
                <div id="admin-menu-panel" class="absolute right-0 top-full mt-1.5 w-44 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-surface)] p-1 z-50 opacity-0 invisible translate-y-[-4px] transition-all duration-[var(--duration-fast)]" style="transition-timing-function: var(--ease-out);">
                  <a
                    href="/admin/posts"
                    class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
                    </svg>
                    图片管理
                  </a>
                  <a
                    href="/admin/tags"
                    class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
                    </svg>
                    标签管理
                  </a>
                  <a
                    href="/admin/auto-rating"
                    class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
                    </svg>
                    自动评级
                  </a>
                  <a
                    href="/admin/import"
                    class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5" />
                    </svg>
                    导入图片
                  </a>
                  <div class="my-1 border-t border-[var(--border-color)] mx-2" />
                  <a
                    href="/admin/settings"
                    class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                    站点设置
                  </a>
                  <a
                    href="/admin/password"
                    class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                    修改密码
                  </a>
                  <form action="/logout" method="post" class="contents">
                    <button
                      type="submit"
                      class="flex items-center gap-2.5 px-3 py-2 rounded-[var(--radius-sm)] text-sm text-[var(--color-danger)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)] w-full text-left"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                      </svg>
                      退出登录
                    </button>
                  </form>
                </div>
              </div>
            ) : (
              <a
                href="/login"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
                登录
              </a>
            )}
            <div class="w-px h-5 bg-[var(--border-color)]" />
            <ThemeToggle client:load />
          </div>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="md:hidden flex items-center justify-center w-9 h-9 rounded-[var(--radius-sm)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
            aria-label="菜单"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    {isAdmin ? (
      <div class="bg-[var(--accent-subtle)] border-b border-[var(--accent-color)]/20 text-[var(--accent-color)] text-center text-xs py-1 font-medium">
        🔒 管理模式 — 可见所有评级内容（含敏感/限制）
      </div>
    ) : (
      <div class="bg-oklch(0.93 0.02 240) dark:bg-oklch(0.25 0.015 260) border-b border-oklch(0.82 0.01 240) dark:border-oklch(0.35 0.015 260) text-center text-xs py-1 text-oklch(0.35 0.02 260) dark:text-oklch(0.7 0.02 240)">
        本项目开发中 | 非管理员仅可浏览<strong class="text-[var(--accent-color)] font-semibold">安全</strong>内容
      </div>
    )}

    <!-- Announcement toast (only when non-empty) -->
    {announcement && (
      <div id="announcement-toast" class="fixed top-4 right-4 z-50 max-w-sm" style="opacity:1; transform:translateX(0); transition: opacity 0.3s, transform 0.3s;">
        <div class="rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-surface)] shadow-lg overflow-hidden" style="border-left: 3px solid var(--accent-color);">
          <div class="flex items-start gap-2 px-4 py-3">
            <div id="announcement-content" class="flex-1 text-sm text-[var(--text-primary)] leading-relaxed"></div>
            <button id="announcement-close" type="button" class="flex-shrink-0 text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors" aria-label="关闭公告">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <div class="h-1 bg-[var(--accent-color)]/20">
            <div id="announcement-progress" class="h-full bg-[var(--accent-color)]" style="width:100%; animation: announcementCountdown 5s linear forwards;"></div>
          </div>
        </div>
      </div>
      <style is:global>
        @keyframes announcementCountdown {
          from { width: 100%; }
          to { width: 0%; }
        }
      </style>
      <script define:vars={{ content: announcement }}>
        (function() {
          var contentEl = document.getElementById('announcement-content');
          var toast = document.getElementById('announcement-toast');
          var closeBtn = document.getElementById('announcement-close');
          if (!contentEl || !toast) return;

          // Simple inline Markdown renderer — ES5 only
          function simpleMarkdown(text) {
            var html = text;
            // Bold: **text**
            html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            // Italic: *text*
            html = html.replace(/\*(.+?)\*/g, '<em>$1</em>');
            // Inline code: `text`
            html = html.replace(/`(.+?)`/g, '<code>$1</code>');
            // Links: [text](url)
            html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" class="text-[var(--accent-color)] hover:underline">$1</a>');
            // Newlines
            html = html.replace(/\n/g, '<br>');
            return html;
          }

          contentEl.innerHTML = simpleMarkdown(content);

          var dismissTimer = null;
          var dismissed = false;

          function dismiss() {
            if (dismissed) return;
            dismissed = true;
            if (dismissTimer) clearTimeout(dismissTimer);
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100%)';
            setTimeout(function() {
              if (toast.parentNode) toast.parentNode.removeChild(toast);
            }, 300);
          }

          // Auto-dismiss after 5s
          dismissTimer = setTimeout(dismiss, 5000);

          // Close button
          if (closeBtn) {
            closeBtn.addEventListener('click', dismiss);
          }
        })();
      </script>
    )}

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-50 hidden" style="background: oklch(0% 0 0 / 0.5); backdrop-filter: blur(4px);">
      <div class="absolute right-0 top-0 bottom-0 w-[min(280px,80vw)] bg-[var(--bg-surface)] border-l border-[var(--border-color)] p-6 flex flex-col gap-2" style="animation: mobileSlideIn var(--duration-normal) var(--ease-out);">
        <button
          id="mobile-menu-close"
          type="button"
          class="self-end flex items-center justify-center w-9 h-9 rounded-[var(--radius-sm)] hover:bg-[var(--accent-subtle)] transition-colors mb-4"
          aria-label="关闭菜单"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
        <a href="/search" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          搜索
        </a>
        <a href="/tags" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h13.5M5.25 8.25V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 20.25 18V8.25m-15 0V6a2.25 2.25 0 0 1 2.25-2.25h10.5A2.25 2.25 0 0 1 20.25 6v2.25m-15 0h13.5" />
          </svg>
          标签
        </a>
        {isAdmin ? (
          <>
            <div class="border-t border-[var(--border-color)] my-2" />
            <a href="/admin/posts" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
              </svg>
              图片管理
            </a>
            <a href="/admin/tags" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
