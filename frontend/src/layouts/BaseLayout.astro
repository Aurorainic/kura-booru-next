---
import ThemeToggle from "@/components/ThemeToggle.tsx";
import AccentPicker from "@/components/AccentPicker.tsx";
import "../styles/globals.css";

const gitTag = import.meta.env.PUBLIC_GIT_TAG || "dev";
const repoUrl = import.meta.env.PUBLIC_REPO_URL || "https://gitea.lainns.xyz/lainsaka/kura-booru-next";
const aiTagEnabled = process.env.ENABLE_AI_TAG_PROCESSING === "true";

interface Props {
  title?: string;
  description?: string;
}

const siteSettings = Astro.locals.siteSettings;
const siteTitle = siteSettings?.site_title || "Kura Booru";
const siteDescription = siteSettings?.site_description || "个人动漫插画收藏与展示平台";
const announcement = siteSettings?.announcement || "";
const headInject = siteSettings?.head_inject || "";

const { title, description } = Astro.props;
const displayTitle = title || siteTitle;
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const metaDescription = description || siteDescription;

const isAdmin = Astro.locals.isAdmin ?? false;

// Accent hue — read from cookie so SSR can set the CSS var before paint
// (no anti-flash script needed). Falls back to default 175.
const accentHueCookie = Astro.cookies.get("kura-accent-hue")?.value;
let accentHue = parseInt(accentHueCookie || "", 10);
if (isNaN(accentHue) || accentHue < 0 || accentHue > 360) accentHue = 175;
const accentHueEnd = accentHue + 25;

// Split site title: first word gets gradient, rest is muted
const titleParts = siteTitle.split(" ");
const gradientPart = titleParts[0];
const mutedPart = titleParts.slice(1).join(" ");
---

<!doctype html>
<html lang="zh-CN" class="dark" style={`--accent-hue: ${accentHue}; --accent-hue-end: ${accentHueEnd};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#7DD3C0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Inline script for theme detection (prevents flash) -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('kura-theme-preference');
        var resolved;
        if (stored === 'light' || stored === 'dark') {
          resolved = stored;
        } else {
          resolved = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        document.documentElement.classList.remove('light', 'dark');
        document.documentElement.classList.add(resolved);

        // Sync per_page from URL to cookie so SSR can apply the preference
        // on the next visit without a client-side redirect.
        var ppUrl = new URLSearchParams(window.location.search).get('per_page');
        if (ppUrl) {
          document.cookie = 'kura-per-page=' + encodeURIComponent(ppUrl) + '; path=/; max-age=31536000; samesite=lax';
        }
      })();
    </script>

    <!-- Head injection from site settings (e.g. analytics scripts) -->
    {headInject && <Fragment set:html={headInject} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="nav-glass sticky top-0 z-40 border-b border-[var(--border-color)]">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 group">
            <img src="/logo.svg" alt={siteTitle} class="h-8 w-8" />
            <span class="gradient-text text-xl font-bold" style="letter-spacing: -0.02em;">{gradientPart}</span>
            {mutedPart && <span class="text-[var(--text-muted)] text-xl font-light" style="letter-spacing: -0.02em;">{mutedPart}</span>}
          </a>

          <!-- Nav links (desktop) -->
          <div class="hidden md:flex items-center gap-2" id="nav-links">
            <a
              href="/search"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
              </svg>
              搜索
            </a>
            <a
              href="/tags"
              class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h13.5M5.25 8.25V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 20.25 18V8.25m-15 0V6a2.25 2.25 0 0 1 2.25-2.25h10.5A2.25 2.25 0 0 1 20.25 6v2.25m-15 0h13.5" />
              </svg>
              标签
            </a>
            <div class="w-px h-5 bg-[var(--border-color)]" />
            {isAdmin ? (
              <div class="flex items-center gap-2">
                <a
                  href="/admin"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--accent-color)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
                  </svg>
                  管理后台
                </a>
                <form action="/logout" method="post" class="contents">
                  <button
                    type="submit"
                    class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--color-danger)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                    </svg>
                    退出
                  </button>
                </form>
              </div>
            ) : (
              <a
                href="/login"
                class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-[var(--radius-sm)] text-sm font-medium text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-all duration-[var(--duration-fast)]"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
                登录
              </a>
            )}
            <div class="w-px h-5 bg-[var(--border-color)]" />
            <AccentPicker client:load />
            <ThemeToggle client:load />
          </div>

          <!-- Mobile menu button -->
          <button
            id="mobile-menu-btn"
            type="button"
            class="md:hidden flex items-center justify-center w-9 h-9 rounded-[var(--radius-sm)] hover:bg-[var(--accent-subtle)] transition-colors duration-[var(--duration-fast)]"
            aria-label="菜单"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Announcement banner (top, slim) — only when non-empty -->
    {announcement && (
      <div
        id="announcement-banner"
        class="announcement-banner sticky top-[var(--nav-height)] z-30 border-b border-[var(--border-color)] overflow-hidden"
        style="background: var(--accent-subtle); max-height: 0; opacity: 0;"
      >
        <div class="max-w-[1400px] mx-auto px-6 lg:px-8 flex items-center gap-3" style="height: 32px;">
          <!-- Megaphone icon -->
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 flex-shrink-0 text-[var(--accent-color)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.839.215 1.691.387 2.56.524m-2.56-.524L21.6 7.5m0 0L18.75 3.75M21.6 7.5l-2.56 8.34m0 0c.839.215 1.691.387 2.56.524m-2.56-.524L7.5 19.5" />
          </svg>
          <!-- Rotating line viewport -->
          <div id="announcement-viewport" class="flex-1 relative overflow-hidden" style="height: 20px;">
            <div id="announcement-track" class="absolute inset-x-0 top-0" style="will-change: transform;">
              <!-- Lines injected by script -->
            </div>
          </div>
          <button
            id="announcement-close"
            type="button"
            class="flex-shrink-0 flex items-center justify-center w-5 h-5 rounded-[var(--radius-sm)] text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--accent-color)]/10 transition-colors"
            aria-label="关闭公告"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      <script define:vars={{ content: announcement }}>
        (function() {
          var banner = document.getElementById('announcement-banner');
          var track = document.getElementById('announcement-track');
          var viewport = document.getElementById('announcement-viewport');
          var closeBtn = document.getElementById('announcement-close');
          if (!banner || !track || !viewport) return;

          // Respect session-level dismissal (don't show again until tab close)
          try {
            if (sessionStorage.getItem('kura-announcement-dismissed') === '1') {
              if (banner.parentNode) banner.parentNode.removeChild(banner);
              return;
            }
          } catch (e) {}

          // ── Simple inline Markdown renderer — ES5 only ──
          function simpleMarkdown(text) {
            var html = text;
            html = html.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/\*(.+?)\*\*/g, '<em>$1</em>');
            html = html.replace(/`(.+?)`/g, '<code>$1</code>');
            html = html.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer" style="color: var(--accent-color); text-decoration: underline;">$1</a>');
            return html;
          }

          // Split into lines (each line = one announcement), trim, drop empties
          var rawLines = String(content || '').split('\n');
          var lines = [];
          for (var i = 0; i < rawLines.length; i++) {
            var t = rawLines[i].trim();
            if (t) lines.push(t);
          }
          if (lines.length === 0) return;

          // Build line elements
          var LINE_H = 20; // matches viewport height
          var lineEls = [];
          for (var j = 0; j < lines.length; j++) {
            var el = document.createElement('div');
            el.className = 'announcement-line';
            el.style.cssText = 'height:' + LINE_H + 'px;line-height:' + LINE_H + 'px;white-space:nowrap;overflow:hidden;position:relative;';
            var inner = document.createElement('span');
            inner.className = 'announcement-line-inner';
            inner.style.cssText = 'display:inline-block;white-space:nowrap;padding-right:48px;will-change:transform;font-size:0.8125rem;color:var(--text-primary);';
            inner.innerHTML = simpleMarkdown(lines[j]);
            el.appendChild(inner);
            track.appendChild(el);
            lineEls.push({ row: el, inner: inner });
          }

          var dismissed = false;
          var rotateTimer = null;
          var idx = 0;

          // Slide banner in
          requestAnimationFrame(function() {
            banner.style.transition = 'max-height 0.35s cubic-bezier(0.16,1,0.3,1), opacity 0.35s cubic-bezier(0.16,1,0.3,1)';
            banner.style.maxHeight = '32px';
            banner.style.opacity = '1';
          });

          // Horizontal scroll for a line that overflows the viewport
          function maybeScrollLine(item) {
            var vw = viewport.clientWidth;
            var iw = item.inner.scrollWidth;
            if (iw <= vw) {
              item.inner.style.transition = 'none';
              item.inner.style.transform = 'translateX(0)';
              return;
            }
            // Distance to scroll: from 0 to -(iw - vw + 24) padding
            var distance = iw - vw + 24;
            var pxPerSec = 28; // slow scroll speed (px/s)
            var durationMs = Math.max(2000, (distance / pxPerSec) * 1000);
            // Reset to start
            item.inner.style.transition = 'none';
            item.inner.style.transform = 'translateX(0)';
            // Force reflow
            void item.inner.offsetWidth;
            // Animate
            item.inner.style.transition = 'transform ' + durationMs + 'ms linear';
            item.inner.style.transform = 'translateX(' + (-distance) + 'px)';
          }

          function showLine(n) {
            // Move track vertically
            track.style.transition = 'transform 0.45s cubic-bezier(0.16,1,0.3,1)';
            track.style.transform = 'translateY(' + (-n * LINE_H) + 'px)';
            // Reset horizontal scroll for all, then set for current after transition
            for (var k = 0; k < lineEls.length; k++) {
              if (k !== n) {
                lineEls[k].inner.style.transition = 'none';
                lineEls[k].inner.style.transform = 'translateX(0)';
              }
            }
            // After vertical slide, start horizontal scroll
            setTimeout(function() {
              if (dismissed) return;
              maybeScrollLine(lineEls[n]);
            }, 500);
          }

          function rotate() {
            if (dismissed || lines.length <= 1) return;
            idx = (idx + 1) % lines.length;
            showLine(idx);
          }

          var ROTATE_INTERVAL = 5000; // time per line before rotating
          function startRotation() {
            if (rotateTimer) clearInterval(rotateTimer);
            rotateTimer = setInterval(rotate, ROTATE_INTERVAL);
          }

          // Initial: show first line, start scroll + rotation
          setTimeout(function() {
            if (dismissed) return;
            showLine(0);
            startRotation();
          }, 400);

          // Re-evaluate scroll on resize
          var resizeTimer = null;
          window.addEventListener('resize', function() {
            if (resizeTimer) clearTimeout(resizeTimer);
            resizeTimer = setTimeout(function() {
              if (!dismissed) maybeScrollLine(lineEls[idx]);
            }, 200);
          });

          function dismiss() {
            if (dismissed) return;
            dismissed = true;
            if (rotateTimer) clearInterval(rotateTimer);
            banner.style.maxHeight = '0';
            banner.style.opacity = '0';
            setTimeout(function() {
              if (banner.parentNode) banner.parentNode.removeChild(banner);
            }, 400);
            // Persist dismissal for this session so it doesn't reappear on navigation
            try { sessionStorage.setItem('kura-announcement-dismissed', '1'); } catch (e) {}
          }

          if (closeBtn) closeBtn.addEventListener('click', dismiss);
        })();
      </script>
    )}

    <!-- Mobile menu overlay -->
    <div id="mobile-menu" class="fixed inset-0 z-50 hidden" style="background: oklch(0% 0 0 / 0.5); backdrop-filter: blur(4px);">
      <div class="absolute right-0 top-0 bottom-0 w-[min(280px,80vw)] bg-[var(--bg-surface)] border-l border-[var(--border-color)] p-6 flex flex-col gap-2" style="animation: mobileSlideIn var(--duration-normal) var(--ease-out);">
        <button
          id="mobile-menu-close"
          type="button"
          class="self-end flex items-center justify-center w-9 h-9 rounded-[var(--radius-sm)] hover:bg-[var(--accent-subtle)] transition-colors mb-4"
          aria-label="关闭菜单"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
          </svg>
        </button>
        <a href="/search" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
          </svg>
          搜索
        </a>
        <a href="/tags" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 8.25h13.5M5.25 8.25V18a2.25 2.25 0 0 0 2.25 2.25h10.5A2.25 2.25 0 0 0 20.25 18V8.25m-15 0V6a2.25 2.25 0 0 1 2.25-2.25h10.5A2.25 2.25 0 0 1 20.25 6v2.25m-15 0h13.5" />
          </svg>
          标签
        </a>
        {isAdmin ? (
          <>
            <div class="border-t border-[var(--border-color)] my-2" />
            <a href="/admin" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
              </svg>
              管理后台
            </a>
            <form action="/logout" method="post" class="contents">
              <button type="submit" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--color-danger)] hover:bg-[var(--accent-subtle)] transition-colors w-full text-left">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                </svg>
                退出登录
              </button>
            </form>
          </>
                ) : (
          <>
            <div class="border-t border-[var(--border-color)] my-2" />
            <a href="/login" class="flex items-center gap-3 px-3 py-3 rounded-[var(--radius-sm)] text-[0.9375rem] font-medium text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
              登录
            </a>
          </>
        )}
      </div>
    </div>

    <!-- Main content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--border-color)] py-6 mt-12">
      <div class="max-w-[1400px] mx-auto px-6 lg:px-8">
        <div class="flex flex-wrap items-center justify-between gap-y-2 text-sm text-[var(--text-muted)]">
          <span class="inline-flex items-center gap-2">
            <a href={repoUrl} target="_blank" rel="noopener noreferrer" class="gradient-text font-medium hover:opacity-80 transition-opacity">{siteTitle} (Next)</a>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full border border-[var(--border-color)] font-mono text-[0.6875rem]">{gitTag}</span>
            {aiTagEnabled && (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-[#8B5CF6] text-white font-medium text-[0.6875rem]" title="AI 标签处理已启用">AI ✦</span>
            )}
          </span>
          <span>{siteDescription}</span>
        </div>
      </div>
    </footer>
  </body>

  <script is:inline>
    // Mobile menu toggle — ES5 compatible
    var mobileBtn = document.getElementById('mobile-menu-btn');
    var mobileMenu = document.getElementById('mobile-menu');
    var mobileClose = document.getElementById('mobile-menu-close');

    if (mobileBtn && mobileMenu && mobileClose) {
      mobileBtn.addEventListener('click', function() {
        mobileMenu.classList.remove('hidden');
      });

      mobileClose.addEventListener('click', function() {
        mobileMenu.classList.add('hidden');
      });

      mobileMenu.addEventListener('click', function(e) {
        if (e.target === mobileMenu) {
          mobileMenu.classList.add('hidden');
        }
      });
    }
  </script>
