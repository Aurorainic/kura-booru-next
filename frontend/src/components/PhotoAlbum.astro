---
import { getPreviewUrl } from "@/lib/api";
import type { Post } from "@/lib/api";

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7 gap-3">
  {posts.map((post) => (
    <a
      href={`/posts/${post.id}`}
      class="group block rounded-xl overflow-hidden card"
    >
      <div class="relative overflow-hidden" style="aspect-ratio: 1 / 1; contain: paint layout;">
        <img
          src={getPreviewUrl(post)}
          alt={post.title || `作品 ${post.id.slice(0, 8)}`}
          width="400"
          height="400"
          class="w-full h-full object-cover"
          decoding="async"
          loading="lazy"
        />
        {/* Hover overlay with tags */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col justify-end p-2">
          {post.tags && post.tags.length > 0 && (
            <div class="flex flex-wrap gap-1">
              {post.tags.slice(0, 5).map((tag) => (
                <span class="text-xs px-1.5 py-0.5 rounded bg-white/20 text-white backdrop-blur-sm truncate max-w-[100px]">
                  {tag.name}
                </span>
              ))}
              {post.tags.length > 5 && (
                <span class="text-xs px-1.5 py-0.5 rounded bg-white/20 text-white backdrop-blur-sm">
                  +{post.tags.length - 5}
                </span>
              )}
            </div>
          )}
        </div>
      </div>
    </a>
  ))}
</div>
