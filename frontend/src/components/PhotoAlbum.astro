---
import { getPreviewUrl, getRatingColorClass, type Post, type Rating } from "@/lib/api";

interface Props {
  posts: Post[];
  isAdmin?: boolean;
}

const { posts, isAdmin = false } = Astro.props;
---

<div class="columns-2 sm:columns-3 md:columns-4 lg:columns-5 xl:columns-6 2xl:columns-7 gap-3">
  {posts.map((post) => (
    <a
      href={`/posts/${post.id}`}
      class="group block mb-3 rounded-xl overflow-hidden card break-inside-avoid"
    >
      <div class="relative overflow-hidden">
        <img
          src={getPreviewUrl(post)}
          alt={post.title || `作品 ${post.id.slice(0, 8)}`}
          width={post.width}
          height={post.height}
          class="w-full h-auto"
          decoding="async"
          loading="lazy"
        />
        {/* Rating badge — only visible to admin */}
        {isAdmin && post.rating !== "safe" && (
          <span class={`absolute top-1.5 left-1.5 px-1.5 py-0.5 text-xs font-bold rounded ${getRatingColorClass(post.rating)} border`}>
            {post.rating === "questionable" ? "敏" : "限"}
          </span>
        )}
        {/* Hover overlay with tags */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex flex-col justify-end p-2">
          {post.tags && post.tags.length > 0 && (
            <div class="flex flex-wrap gap-1">
              {post.tags.slice(0, 5).map((tag) => (
                <span class="text-xs px-1.5 py-0.5 rounded bg-white/20 text-white backdrop-blur-sm truncate max-w-[100px]">
                  {tag.name}
                </span>
              ))}
              {post.tags.length > 5 && (
                <span class="text-xs px-1.5 py-0.5 rounded bg-white/20 text-white backdrop-blur-sm">
                  +{post.tags.length - 5}
                </span>
              )}
            </div>
          )}
        </div>
      </div>
    </a>
  ))}
</div>