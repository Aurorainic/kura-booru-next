---
import BaseLayout from "@/layouts/BaseLayout.astro";

const isAdmin = Astro.locals.isAdmin ?? false;

if (!isAdmin) {
  return Astro.redirect("/login");
}
---

<BaseLayout title="导入图片">
  <div class="max-w-4xl mx-auto px-6 lg:px-8 py-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">
          <span class="gradient-text">导入图片</span>
        </h1>
        <p class="text-sm text-[var(--text-muted)] mt-1">
          通过链接批量导入插画，每行一个 URL
        </p>
      </div>
      <a
        href="/admin/posts"
        class="text-sm text-[var(--text-muted)] hover:text-[var(--accent-color)] transition-colors"
      >
        ← 返回管理
      </a>
    </div>

    <!-- Import form -->
    <div class="card p-6 mb-6">
      <label for="urls-input" class="block text-sm font-medium text-[var(--text-muted)] mb-2">
        图片链接（每行一个）
      </label>
      <textarea
        id="urls-input"
        rows="8"
        placeholder="https://www.pixiv.net/artworks/12345&#10;https://x.com/user/status/67890&#10;https://danbooru.donmai.us/posts/11111"
        class="w-full px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] placeholder:text-[var(--text-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] font-mono text-sm resize-y"
      ></textarea>
      <div class="flex items-center justify-between mt-3">
        <span id="url-count" class="text-xs text-[var(--text-muted)]">0 个有效链接</span>
        <button
          id="import-btn"
          type="button"
          class="px-6 py-2 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all duration-[var(--duration-fast)] disabled:opacity-50 disabled:cursor-not-allowed"
        >
          开始导入
        </button>
      </div>
    </div>

    <!-- Results area -->
    <div id="results-area" class="hidden">
      <div class="card overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-color)] flex items-center justify-between">
          <h2 class="text-sm font-medium text-[var(--text-muted)]">
            实时处理结果
          </h2>
          <span id="results-summary" class="text-xs text-[var(--text-muted)]"></span>
        </div>
        <div id="results-list" class="divide-y divide-[var(--border-color)] max-h-96 overflow-y-auto">
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script is:inline>
  var urlsInput = document.getElementById('urls-input');
  var urlCount = document.getElementById('url-count');
  var importBtn = document.getElementById('import-btn');
  var resultsArea = document.getElementById('results-area');
  var resultsList = document.getElementById('results-list');
  var resultsSummary = document.getElementById('results-summary');

  // Update URL count on input
  urlsInput.addEventListener('input', function() {
    var urls = getValidUrls();
    urlCount.textContent = urls.length + ' 个有效链接';
  });

  function getValidUrls() {
    return urlsInput.value
      .split('\n')
      .map(function(line) { return line.trim(); })
      .filter(function(line) { return line.length > 0; });
  }

  function escapeHtml(text) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(text));
    return div.innerHTML;
  }

  function setStatusIcon(status) {
    if (status === 'success') return '<span class="text-green-400">✅</span>';
    if (status === 'duplicate') return '<span class="text-yellow-400">⚠️</span>';
    if (status === 'too_large') return '<span class="text-yellow-400">⚠️</span>';
    if (status === 'failed') return '<span class="text-red-400">❌</span>';
    return '<span class="text-[var(--text-muted)]">⏳</span>';
  }

  function updateRow(index, status, detail, extra) {
    var row = document.getElementById('import-row-' + index);
    if (!row) return;
    var iconEl = row.querySelector('.row-icon');
    var detailEl = row.querySelector('.row-detail');
    if (iconEl) iconEl.innerHTML = setStatusIcon(status);
    if (detailEl) detailEl.textContent = detail || '';
    // Store extra data (post_id etc.) as data attributes
    if (extra) {
      if (extra.post_id) row.setAttribute('data-post-id', extra.post_id);
      if (extra.existing_post_id) row.setAttribute('data-existing-post-id', extra.existing_post_id);
    }
  }

  // Import button click
  importBtn.addEventListener('click', async function() {
    var urls = getValidUrls();
    if (urls.length === 0) {
      alert('请输入至少一个链接');
      return;
    }

    importBtn.disabled = true;
    importBtn.textContent = '导入中…';
    resultsList.innerHTML = '';
    resultsArea.classList.remove('hidden');
    resultsSummary.textContent = '处理中…';

    try {
      var resp = await fetch('/api/tasks/web-import', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ urls: urls }),
      });

      if (!resp.ok) {
        var errData = await resp.json().catch(function() { return {}; });
        alert('导入失败: ' + (errData.detail || 'HTTP ' + resp.status));
        return;
      }

      var data = await resp.json();
      var results = data.results || [];
      var taskIds = [];
      var enqueueErrors = 0;

      // Render initial rows — ⏳ for queued, ✗ for errors
      results.forEach(function(result, index) {
        var url = urls[index] || '未知链接';
        var div = document.createElement('div');
        div.id = 'import-row-' + index;
        div.className = 'px-4 py-2 flex items-center gap-2 text-sm';

        if (result.status === 'queued' && result.task_id) {
          taskIds.push(result.task_id);
          div.innerHTML =
            '<span class="row-icon">' + setStatusIcon('pending') + '</span>' +
            '<span class="text-[var(--text-primary)] truncate flex-1">' + escapeHtml(url) + '</span>' +
            '<span class="row-detail text-xs text-[var(--text-muted)]">处理中</span>';
        } else {
          enqueueErrors++;
          div.innerHTML =
            '<span class="row-icon">' + setStatusIcon('failed') + '</span>' +
            '<span class="text-[var(--text-primary)] truncate flex-1">' + escapeHtml(url) + '</span>' +
            '<span class="row-detail text-xs text-red-400">入队失败</span>';
        }

        resultsList.appendChild(div);
      });

      // If there are queued tasks, open SSE stream
      if (taskIds.length > 0) {
        connectSSE(taskIds, enqueueErrors);
      } else {
        resultsSummary.textContent = enqueueErrors + ' 全部失败';
      }
    } catch (err) {
      alert('网络错误: ' + err.message);
      resultsSummary.textContent = '';
    } finally {
      importBtn.disabled = false;
      importBtn.textContent = '开始导入';
    }
  });

  function connectSSE(taskIds, enqueueErrors) {
    var es = new EventSource('/api/tasks/web-import/stream?task_ids=' + taskIds.join(','));
    var succeeded = enqueueErrors > 0 ? 0 : 0;
    var failed = enqueueErrors;
    var total = taskIds.length + enqueueErrors;

    es.addEventListener('progress', function(e) {
      var data = JSON.parse(e.data);
      var extra = {};
      if (data.post_id) extra.post_id = data.post_id;
      if (data.existing_post_id) extra.existing_post_id = data.existing_post_id;
      updateRow(data.url_index, data.status, data.detail, extra);
    });

    es.addEventListener('done', function(e) {
      var data = JSON.parse(e.data);
      var parts = [];
      if (data.succeeded > 0) parts.push(data.succeeded + ' 成功');
      if (data.failed > 0) parts.push(data.failed + ' 失败');
      if (data.timed_out > 0) parts.push(data.timed_out + ' 超时');
      resultsSummary.textContent = parts.join('，') || '完成';
      es.close();
    });

    es.addEventListener('error', function() {
      // EventSource auto-reconnects once; if still failing, show error
      if (es.readyState === EventSource.CLOSED) {
        resultsSummary.textContent = '连接中断，部分结果可能未更新';
      }
    });
  }
</script>
