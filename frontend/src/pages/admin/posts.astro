---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  fetchPosts, clampPerPage, emptyPostsResponse,
  getRatingColorClass, getRatingLabel, getSourceSiteLabel,
  getThumbUrl, formatFileSize, formatDate,
  type Rating,
} from "@/lib/api";

// Admin-only page: redirect non-admins to login
const isAdmin = Astro.locals.isAdmin ?? false;
const ssrCookie = Astro.locals.ssrCookie;

if (!isAdmin) {
  return Astro.redirect("/login");
}

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const perPage = 40;
const ratingFilter = (Astro.url.searchParams.get("rating") || "") as Rating | "";

let data;
try {
  data = await fetchPosts(page, perPage, ratingFilter || undefined, ssrCookie);
} catch {
  data = emptyPostsResponse();
}

const { items: posts, total, total_pages } = data;

function buildPageUrl(p: number, r: string): string {
  const params = new URLSearchParams();
  if (p > 1) params.set("page", String(p));
  if (r) params.set("rating", r);
  const qs = params.toString();
  return qs ? `/admin/posts?${qs}` : "/admin/posts";
}

const ratingOptions: { value: string; label: string }[] = [
  { value: "", label: "全部" },
  { value: "safe", label: "公开" },
  { value: "questionable", label: "敏感" },
  { value: "explicit", label: "限制" },
];
---

<BaseLayout title="图片管理">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-8 py-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">
          <span class="gradient-text">图片管理</span>
        </h1>
        <p class="text-sm text-[var(--text-muted)] mt-1">{total} 张插画（含所有评级）</p>
      </div>

      <!-- Rating filter -->
      <div class="flex items-center gap-2 text-sm">
        <span class="text-[var(--text-muted)]">评级:</span>
        {ratingOptions.map(opt => (
          <a
            href={buildPageUrl(1, opt.value)}
            class={`filter-chip ${ratingFilter === opt.value ? "active" : ""}`}
          >
            {opt.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Posts table -->
    {posts.length > 0 ? (
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--border-color)] text-left text-[var(--text-muted)]">
              <th class="py-3 px-2 w-16">预览</th>
              <th class="py-3 px-2">标题 / ID</th>
              <th class="py-3 px-2">来源</th>
              <th class="py-3 px-2">评级</th>
              <th class="py-3 px-2">大小</th>
              <th class="py-3 px-2">时间</th>
              <th class="py-3 px-2">操作</th>
            </tr>
          </thead>
          <tbody>
            {posts.map((post) => (
              <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-surface)] transition-colors">
                <td class="py-2 px-2">
                  <a href={`/posts/${post.id}`}>
                    <img
                      src={post.thumb_key ? getThumbUrl(post) : "/placeholder.svg"}
                      alt=""
                      class="w-12 h-12 object-cover rounded"
                      loading="lazy"
                    />
                  </a>
                </td>
                <td class="py-2 px-2">
                  <a href={`/posts/${post.id}`} class="text-[var(--text-primary)] hover:text-[var(--accent-color)] font-medium">
                    {post.title || post.id.slice(0, 8)}
                  </a>
                </td>
                <td class="py-2 px-2 text-[var(--text-muted)]">
                  {getSourceSiteLabel(post.source_site)}
                </td>
                <td class="py-2 px-2">
                  <span class={`px-2 py-0.5 text-xs font-bold rounded border ${getRatingColorClass(post.rating)}`}>
                    {getRatingLabel(post.rating)}
                  </span>
                </td>
                <td class="py-2 px-2 text-[var(--text-muted)]">
                  {formatFileSize(post.file_size)}
                </td>
                <td class="py-2 px-2 text-[var(--text-muted)]">
                  {formatDate(post.created_at)}
                </td>
                <td class="py-2 px-2">
                  <div class="flex items-center gap-2">
                    <select
                      class="rating-admin-select text-xs px-1.5 py-0.5 rounded border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)]"
                      data-post-id={post.id}
                      data-current-rating={post.rating}
                    >
                      <option value="safe" selected={post.rating === "safe"}>公开</option>
                      <option value="questionable" selected={post.rating === "questionable"}>敏感</option>
                      <option value="explicit" selected={post.rating === "explicit"}>限制</option>
                    </select>
                    <button
                      class="delete-post-btn text-red-400 hover:text-red-300 transition-colors p-1"
                      data-post-id={post.id}
                      title="删除"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    </button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="flex flex-col items-center justify-center py-24 text-[var(--text-muted)]">
        <p class="text-xl mb-2">无符合条件的插画</p>
      </div>
    )}

    <!-- Pagination (simple) -->
    {total_pages > 1 && (
      <div class="flex items-center justify-center gap-4 mt-8">
        {page > 1 && (
          <a
            href={buildPageUrl(page - 1, ratingFilter)}
            class="px-4 py-2 rounded-[var(--radius-sm)] bg-[var(--bg-surface)] border border-[var(--border-color)] text-sm text-[var(--text-primary)] hover:border-[var(--accent-color)] transition-colors"
          >
            ← 上一页
          </a>
        )}
        <span class="text-sm text-[var(--text-muted)]">
          第 {page} / {total_pages} 页
        </span>
        {page < total_pages && (
          <a
            href={buildPageUrl(page + 1, ratingFilter)}
            class="px-4 py-2 rounded-[var(--radius-sm)] bg-[var(--bg-surface)] border border-[var(--border-color)] text-sm text-[var(--text-primary)] hover:border-[var(--accent-color)] transition-colors"
          >
            下一页 →
          </a>
        )}
      </div>
    )}
  </div>
</BaseLayout>

<script is:inline>
  // Inline rating change handler (must be plain JS — is:inline is not compiled)
  document.querySelectorAll('.rating-admin-select').forEach(function(sel) {
    sel.addEventListener('change', async function(e) {
      var select = e.target;
      var postId = select.dataset.postId;
      var newRating = select.value;
      var originalRating = select.dataset.currentRating || 'safe';
      try {
        var resp = await fetch('/api/posts/' + postId, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ rating: newRating }),
        });
        if (!resp.ok) {
          select.value = originalRating;
          alert('评级更新失败 (HTTP ' + resp.status + ')');
        } else {
          select.dataset.currentRating = newRating;
          // Update badge in same row for instant feedback
          var row = select.closest('tr');
          if (row) {
            var badge = row.querySelector('td:nth-child(4) span');
            if (badge) {
              var labelMap = { safe: '公开', questionable: '敏感', explicit: '限制' };
              var classMap = { safe: 'rating-safe', questionable: 'rating-questionable', explicit: 'rating-explicit' };
              badge.textContent = labelMap[newRating] || newRating;
              badge.className = 'px-2 py-0.5 text-xs font-bold rounded border ' + (classMap[newRating] || 'rating-safe');
            }
          }
        }
      } catch (err) {
        select.value = originalRating;
        alert('网络错误');
      }
    });
  });

  // Delete post handler
  document.querySelectorAll('.delete-post-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var postId = btn.dataset.postId;
      if (!confirm('确定要删除这张插画吗？此操作不可恢复，将同时删除存储文件。')) return;
      try {
        var resp = await fetch('/api/posts/' + postId, {
          method: 'DELETE',
        });
        if (resp.ok) {
          var row = btn.closest('tr');
          if (row) row.remove();
        } else {
          alert('删除失败 (HTTP ' + resp.status + ')');
        }
      } catch (err) {
        alert('网络错误');
      }
    });
  });
</script>