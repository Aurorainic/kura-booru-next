---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  fetchAutoRatingRules,
  fetchTags,
  getRatingColorClass,
  getRatingLabel,
  type Rating,
  type AutoRatingRule,
  type Tag,
} from "@/lib/api";

const isAdmin = Astro.locals.isAdmin ?? false;
const ssrCookie = Astro.locals.ssrCookie;

if (!isAdmin) {
  return Astro.redirect("/login");
}

let rules: AutoRatingRule[] = [];
try {
  rules = await fetchAutoRatingRules(ssrCookie);
} catch {
  // Rules fetch failed, show empty state
}

// Fetch existing tags for autocomplete
let tags: Tag[] = [];
try {
  const tagsData = await fetchTags(undefined, "count", 1, 500, ssrCookie);
  tags = tagsData.items;
} catch {
  // Tags fetch failed
}
---

<BaseLayout title="自动评级规则">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">
          <span class="gradient-text">自动评级规则</span>
        </h1>
        <p class="text-sm text-[var(--text-muted)] mt-1">
          含有特定标签的插画将自动设为对应评级（仅升级，不降级）
        </p>
      </div>
      <a
        href="/admin/posts"
        class="text-sm text-[var(--text-muted)] hover:text-[var(--color-cyan-accent-start)] transition-colors"
      >
        ← 返回管理
      </a>
    </div>

    <!-- Add rule form -->
    <div class="card p-6 mb-6">
      <h2 class="text-sm font-medium text-[var(--text-muted)] mb-4">添加规则</h2>
      <form id="add-rule-form" class="flex items-end gap-3">
        <div class="flex-1">
          <label for="tag-name-input" class="block text-sm font-medium text-[var(--text-muted)] mb-1">标签名称</label>
          <div class="relative">
            <input
              type="text"
              id="tag-name-input"
              placeholder="输入标签名…"
              autocomplete="off"
              required
              class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]"
            />
            <div id="tag-suggestions" class="absolute z-50 mt-1 w-full rounded-lg bg-[var(--bg-surface)] border border-[var(--border-color)] shadow-lg overflow-hidden hidden max-h-48 overflow-y-auto"></div>
          </div>
        </div>
        <div class="w-40">
          <label for="rating-select" class="block text-sm font-medium text-[var(--text-muted)] mb-1">目标评级</label>
          <select
            id="rating-select"
            class="w-full px-3 py-2 rounded-lg border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent)]"
          >
            <option value="questionable">敏感</option>
            <option value="explicit">限制</option>
          </select>
        </div>
        <button
          type="submit"
          id="add-btn"
          class="px-4 py-2 rounded-lg gradient-bg text-white font-medium hover:opacity-90 transition-opacity whitespace-nowrap"
        >
          添加
        </button>
      </form>
      <div id="add-error" class="text-sm text-red-400 mt-2 hidden"></div>
    </div>

    <!-- Rules list -->
    {rules.length > 0 ? (
      <div class="card overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-color)]">
          <h2 class="text-sm font-medium text-[var(--text-muted)]">
            当前规则（{rules.length} 条）
          </h2>
        </div>
        <table class="w-full">
          <thead>
            <tr class="border-b border-[var(--border-color)]">
              <th class="text-left px-4 py-3 text-sm font-medium text-[var(--text-muted)]">标签</th>
              <th class="text-left px-4 py-3 text-sm font-medium text-[var(--text-muted)]">目标评级</th>
              <th class="text-right px-4 py-3 text-sm font-medium text-[var(--text-muted)]">操作</th>
            </tr>
          </thead>
          <tbody id="rules-tbody">
            {rules.map((rule) => (
              <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-primary)] transition-colors" data-rule-id={rule.id}>
                <td class="px-4 py-2">
                  <span class="text-[var(--text-primary)] font-medium">{rule.tag_name}</span>
                </td>
                <td class="px-4 py-2">
                  <span class={`px-2 py-0.5 text-xs font-bold rounded border ${getRatingColorClass(rule.target_rating)}`}>
                    {getRatingLabel(rule.target_rating)}
                  </span>
                </td>
                <td class="px-4 py-2 text-right">
                  <button
                    class="delete-rule-btn text-red-400 hover:text-red-300 transition-colors p-1"
                    data-rule-id={rule.id}
                    title="删除规则"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                  </button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="flex flex-col items-center justify-center py-16 text-[var(--text-muted)]">
        <p class="text-xl mb-2">暂无自动评级规则</p>
        <p class="text-sm">添加规则后，含有对应标签的插画将自动设为指定评级</p>
      </div>
    )}
  </div>
</BaseLayout>

<script define:vars={{ tagNames: tags.map((t: any) => t.name) }}>
  var TAG_NAMES = tagNames;
</script>

<script is:inline>
  // Tag autocomplete
  var tagInput = document.getElementById('tag-name-input');
  var suggestionsDiv = document.getElementById('tag-suggestions');
  var debounceTimer = null;

  tagInput.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    var val = tagInput.value.trim().toLowerCase();
    if (val.length < 1) {
      suggestionsDiv.classList.add('hidden');
      return;
    }
    debounceTimer = setTimeout(function() {
      var matches = (window.TAG_NAMES || []).filter(function(t) { return t.indexOf(val) >= 0; }).slice(0, 10);
      if (matches.length === 0) {
        suggestionsDiv.classList.add('hidden');
        return;
      }
      suggestionsDiv.innerHTML = matches.map(function(name) {
        return '<button type="button" class="w-full px-3 py-2 text-left text-sm text-[var(--text-primary)] hover:bg-[var(--border-color)] transition-colors tag-suggestion" data-tag="' + name + '">' + name + '</button>';
      }).join('');
      suggestionsDiv.classList.remove('hidden');
    }, 200);
  });

  suggestionsDiv.addEventListener('click', function(e) {
    var btn = e.target.closest('.tag-suggestion');
    if (btn) {
      tagInput.value = btn.dataset.tag;
      suggestionsDiv.classList.add('hidden');
    }
  });

  tagInput.addEventListener('blur', function() {
    setTimeout(function() { suggestionsDiv.classList.add('hidden'); }, 200);
  });

  // Add rule form
  var addForm = document.getElementById('add-rule-form');
  var addBtn = document.getElementById('add-btn');
  var addError = document.getElementById('add-error');

  addForm.addEventListener('submit', async function(e) {
    e.preventDefault();
    addError.classList.add('hidden');
    var tagName = tagInput.value.trim().toLowerCase();
    var rating = document.getElementById('rating-select').value;
    if (!tagName) return;

    addBtn.disabled = true;
    addBtn.textContent = '添加中…';

    try {
      var resp = await fetch('/api/auto-rating-rules/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tag_name: tagName, target_rating: rating }),
      });
      if (resp.ok) {
        window.location.reload();
      } else {
        var data = await resp.json().catch(function() { return {}; });
        addError.textContent = data.detail || '添加失败';
        addError.classList.remove('hidden');
      }
    } catch (err) {
      addError.textContent = '网络错误';
      addError.classList.remove('hidden');
    } finally {
      addBtn.disabled = false;
      addBtn.textContent = '添加';
    }
  });

  // Delete rule
  document.querySelectorAll('.delete-rule-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var ruleId = btn.dataset.ruleId;
      if (!confirm('确定删除此规则？')) return;
      try {
        var resp = await fetch('/api/auto-rating-rules/' + ruleId, {
          method: 'DELETE',
        });
        if (resp.ok) {
          var row = btn.closest('tr');
          if (row) row.remove();
        } else {
          alert('删除失败');
        }
      } catch (err) {
        alert('网络错误');
      }
    });
  });
</script>

<script define:vars={{ tagNames: tags.map((t: any) => t.name) }}>
  var TAG_NAMES = tagNames;
</script>
