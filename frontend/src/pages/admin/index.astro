<!-- ── Tab switching ── -->
<script is:inline>
(function() {
  var manageGroup = ['posts', 'tags', 'auto-rating'];
  var settingsGroup = ['settings', 'password'];

  function switchTab(tab) {
    // Hide all panels
    document.querySelectorAll('.admin-panel').forEach(function(p) {
      p.style.display = 'none';
    });

    // Show target panel with animation
    var panel = document.getElementById('panel-' + tab);
    if (panel) {
      panel.style.display = '';
      panel.style.opacity = '0';
      panel.style.transform = 'translateY(8px)';
      requestAnimationFrame(function() {
        panel.style.transition = 'opacity var(--duration-normal) var(--ease-out), transform var(--duration-normal) var(--ease-out)';
        panel.style.opacity = '1';
        panel.style.transform = 'translateY(0)';
      });
    }

    // Update sub-tab active states
    document.querySelectorAll('.admin-subtab').forEach(function(t) {
      t.classList.remove('active');
    });
    var activeLink = document.querySelector('.admin-subtab[data-tab="' + tab + '"]');
    if (activeLink) activeLink.classList.add('active');

    // Show correct sub-tab group
    var subtabsManage = document.getElementById('subtabs-manage');
    var subtabsSettings = document.getElementById('subtabs-settings');
    if (manageGroup.indexOf(tab) >= 0) {
      subtabsManage.style.display = '';
      subtabsSettings.style.display = 'none';
    } else {
      subtabsManage.style.display = 'none';
      subtabsSettings.style.display = '';
    }

    // Update top-level tab indicators
    document.querySelectorAll('.admin-top-tab').forEach(function(btn) {
      var group = btn.getAttribute('data-group');
      var indicator = btn.querySelector('.admin-top-tab-indicator');
      var isActive = (group === 'manage' && manageGroup.indexOf(tab) >= 0) ||
                     (group === 'settings' && settingsGroup.indexOf(tab) >= 0);
      btn.style.color = isActive ? 'var(--text-primary)' : 'var(--text-muted)';
      if (indicator) indicator.style.display = isActive ? '' : 'none';
    });
  }

  // Intercept sub-tab clicks for client-side navigation
  document.querySelectorAll('.admin-subtab').forEach(function(link) {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      var tab = this.getAttribute('data-tab');
      if (!tab) return;
      var url = new URL(window.location);
      url.searchParams.set('tab', tab);
      history.pushState({}, '', url);
      switchTab(tab);
    });
  });

  // Top-level tab clicks
  document.querySelectorAll('.admin-top-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var group = this.getAttribute('data-group');
      var defaultTab = group === 'manage' ? 'posts' : 'settings';
      var url = new URL(window.location);
      url.searchParams.set('tab', defaultTab);
      history.pushState({}, '', url);
      switchTab(defaultTab);
    });
  });

  // Back/forward
  window.addEventListener('popstate', function() {
    var params = new URLSearchParams(window.location.search);
    var tab = params.get('tab') || 'posts';
    switchTab(tab);
  });

  // Initialize top-level tab styling
  var currentTab = new URLSearchParams(window.location.search).get('tab') || 'posts';
  switchTab(currentTab);

  // Tags filter form — include tab param
  var filterForm = document.getElementById('filter-form');
  if (filterForm) {
    filterForm.addEventListener('submit', function() {
      var hiddenTab = document.createElement('input');
      hiddenTab.type = 'hidden';
      hiddenTab.name = 'tab';
      hiddenTab.value = 'tags';
      filterForm.appendChild(hiddenTab);
    });
  }
})();
</script>

<!-- ── Posts panel scripts ── -->
<script is:inline>
(function() {
  document.querySelectorAll('.rating-admin-select').forEach(function(sel) {
    sel.addEventListener('change', async function(e) {
      var select = e.target;
      var postId = select.dataset.postId;
      var newRating = select.value;
      var originalRating = select.dataset.currentRating || 'safe';
      try {
        var resp = await fetch('/api/posts/' + postId, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ rating: newRating }),
        });
        if (!resp.ok) {
          select.value = originalRating;
          alert('评级更新失败 (HTTP ' + resp.status + ')');
        } else {
          select.dataset.currentRating = newRating;
          var row = select.closest('tr');
          if (row) {
            var badge = row.querySelector('td:nth-child(5) span');
            if (badge) {
              var labelMap = { safe: '公开', questionable: '敏感', explicit: '限制' };
              var classMap = { safe: 'rating-safe', questionable: 'rating-questionable', explicit: 'rating-explicit' };
              badge.textContent = labelMap[newRating] || newRating;
              badge.className = 'px-2 py-0.5 text-xs font-bold rounded border ' + (classMap[newRating] || 'rating-safe');
            }
          }
        }
      } catch (err) {
        select.value = originalRating;
        alert('网络错误');
      }
    });
  });

  document.querySelectorAll('.delete-post-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var postId = btn.dataset.postId;
      if (!confirm('确定要删除这张插画吗？此操作不可恢复，将同时删除存储文件。')) return;
      try {
        var resp = await fetch('/api/posts/' + postId, { method: 'DELETE' });
        if (resp.ok) {
          var row = btn.closest('tr');
          if (row) row.remove();
        } else {
          alert('删除失败 (HTTP ' + resp.status + ')');
        }
      } catch (err) {
        alert('网络错误');
      }
    });
  });
})();
</script>

<!-- ── Tags panel scripts ── -->
<script is:inline>
(function() {
  document.querySelectorAll('.save-tag-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var tagId = btn.dataset.tagId;
      var row = btn.closest('tr');
      var category = row.querySelector('.tag-category-select').value;
      var danbooruName = row.querySelector('.tag-danbooru-input').value;
      var translation = row.querySelector('.tag-translation-input').value;
      btn.disabled = true;
      btn.textContent = '…';
      try {
        var resp = await fetch('/api/admin/tags/' + tagId, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ category: category, danbooru_name: danbooruName || null, translation: translation || null }),
        });
        if (resp.ok) {
          btn.textContent = '✓';
          setTimeout(function() { btn.textContent = '保存'; }, 1500);
        } else {
          btn.textContent = '✗';
          var data = await resp.json().catch(function() { return {}; });
          alert(data.detail || '保存失败');
          btn.textContent = '保存';
        }
      } catch (err) {
        btn.textContent = '✗';
        alert('网络错误');
        btn.textContent = '保存';
      } finally {
        btn.disabled = false;
      }
    });
  });

  var reprocessBtn = document.getElementById('reprocess-btn');
  if (reprocessBtn) {
    reprocessBtn.addEventListener('click', async function() {
      if (!confirm('处理所有未处理的标签？')) return;
      try {
        var resp = await fetch('/api/admin/tags/reprocess', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ force: false }),
        });
        if (resp.ok) { var data = await resp.json(); alert('已加入队列，Job ID: ' + data.job_id); }
        else { alert('触发失败'); }
      } catch (err) { alert('网络错误'); }
    });
  }

  var reprocessForceBtn = document.getElementById('reprocess-force-btn');
  if (reprocessForceBtn) {
    reprocessForceBtn.addEventListener('click', async function() {
      if (!confirm('⚠️ 确定重新处理所有标签？此操作将覆盖现有分类和翻译。')) return;
      try {
        var resp = await fetch('/api/admin/tags/reprocess', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ force: true }),
        });
        if (resp.ok) { var data = await resp.json(); alert('已加入队列，Job ID: ' + data.job_id); }
        else { alert('触发失败'); }
      } catch (err) { alert('网络错误'); }
    });
  }

  var mergeForm = document.getElementById('merge-form');
  if (mergeForm) {
    mergeForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var sourceId = document.getElementById('merge-source-id').value.trim();
      var targetId = document.getElementById('merge-target-id').value.trim();
      if (!sourceId || !targetId) return;
      if (!confirm('确定将源标签合并到目标标签？此操作不可撤销。')) return;
      try {
        var resp = await fetch('/api/admin/tags/merge', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ source_tag_id: sourceId, target_tag_id: targetId }),
        });
        if (resp.ok) {
          var data = await resp.json();
          alert('合并完成：移动 ' + data.posts_moved + ' 个帖子，跳过 ' + data.posts_skipped + ' 个');
          window.location.reload();
        } else {
          var err = await resp.json().catch(function() { return {}; });
          alert(err.detail || '合并失败');
        }
      } catch (err) { alert('网络错误'); }
    });
  }
})();
</script>

<!-- ── Auto-rating panel scripts ── -->
<script is:inline>
(function() {
  var tagInput = document.getElementById('tag-name-input');
  var suggestionsDiv = document.getElementById('tag-suggestions');
  if (!tagInput || !suggestionsDiv) return;

  var debounceTimer = null;
  tagInput.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    var val = tagInput.value.trim().toLowerCase();
    if (val.length < 1) { suggestionsDiv.classList.add('hidden'); return; }
    debounceTimer = setTimeout(function() {
      var matches = (window.TAG_NAMES || []).filter(function(t) { return t.indexOf(val) >= 0; }).slice(0, 10);
      if (matches.length === 0) { suggestionsDiv.classList.add('hidden'); return; }
      suggestionsDiv.innerHTML = matches.map(function(name) {
        return '<button type="button" class="w-full px-3 py-2 text-left text-sm text-[var(--text-primary)] hover:bg-[var(--accent-subtle)] transition-colors tag-suggestion" data-tag="' + name + '">' + name + '</button>';
      }).join('');
      suggestionsDiv.classList.remove('hidden');
    }, 200);
  });

  suggestionsDiv.addEventListener('click', function(e) {
    var btn = e.target.closest('.tag-suggestion');
    if (btn) { tagInput.value = btn.dataset.tag; suggestionsDiv.classList.add('hidden'); }
  });

  tagInput.addEventListener('blur', function() {
    setTimeout(function() { suggestionsDiv.classList.add('hidden'); }, 200);
  });

  var addForm = document.getElementById('add-rule-form');
  var addBtn = document.getElementById('add-btn');
  var addError = document.getElementById('add-error');
  if (addForm) {
    addForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      addError.classList.add('hidden');
      var tagName = tagInput.value.trim().toLowerCase();
      var rating = document.getElementById('rating-select').value;
      if (!tagName) return;
      addBtn.disabled = true;
      addBtn.textContent = '添加中…';
      try {
        var resp = await fetch('/api/auto-rating-rules/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tag_name: tagName, target_rating: rating }),
        });
        if (resp.ok) { window.location.reload(); }
        else { var data = await resp.json().catch(function() { return {}; }); addError.textContent = data.detail || '添加失败'; addError.classList.remove('hidden'); }
      } catch (err) { addError.textContent = '网络错误'; addError.classList.remove('hidden'); }
      finally { addBtn.disabled = false; addBtn.textContent = '添加'; }
    });
  }

  document.querySelectorAll('.delete-rule-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var ruleId = btn.dataset.ruleId;
      if (!confirm('确定删除此规则？')) return;
      try {
        var resp = await fetch('/api/auto-rating-rules/' + ruleId, { method: 'DELETE' });
        if (resp.ok) {
          // Remove from desktop table row or mobile card
          var row = btn.closest('tr') || btn.closest('[data-rule-id]');
          if (row) row.remove();
          // Also remove matching element in the other view
          var match = document.querySelector('[data-rule-id="' + ruleId + '"]');
          if (match && match !== row) match.remove();
        }
        else { alert('删除失败'); }
      } catch (err) { alert('网络错误'); }
    });
  });
})();
</script>

<!-- ── Settings panel scripts ── -->
<script is:inline>
(function() {
  var origPg = document.getElementById('database_url') ? document.getElementById('database_url').value : '';
  var origRedis = document.getElementById('redis_url') ? document.getElementById('redis_url').value : '';
  var pgTested = false;
  var redisTested = false;
  var pgInput = document.getElementById('database_url');
  var redisInput = document.getElementById('redis_url');
  var pgModified = document.getElementById('pg-modified');
  var redisModified = document.getElementById('redis-modified');

  if (pgInput) {
    pgInput.addEventListener('input', function() {
      if (pgInput.value !== origPg) { pgModified.classList.remove('hidden'); pgTested = false; }
      else { pgModified.classList.add('hidden'); pgTested = true; }
    });
  }
  if (redisInput) {
    redisInput.addEventListener('input', function() {
      if (redisInput.value !== origRedis) { redisModified.classList.remove('hidden'); redisTested = false; }
      else { redisModified.classList.add('hidden'); redisTested = true; }
    });
  }

  var testPgBtn = document.getElementById('test-pg-btn');
  var pgResult = document.getElementById('pg-test-result');
  if (testPgBtn) {
    testPgBtn.addEventListener('click', function() {
      var url = pgInput.value;
      if (!url) return;
      testPgBtn.disabled = true;
      testPgBtn.textContent = '测试中…';
      pgResult.classList.add('hidden');
      var apiBase = window.__KURA_API_BASE || '/api';
      fetch(apiBase + '/settings/test-pg', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url: url }) })
        .then(function(resp) { return resp.json(); })
        .then(function(data) {
          pgResult.classList.remove('hidden');
          if (data.ok) { pgResult.textContent = '✓ ' + data.detail; pgResult.className = 'text-xs mt-1 text-green-400'; testPgBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-green-500 text-sm font-medium text-green-400 whitespace-nowrap'; pgTested = true; }
          else { pgResult.textContent = '✗ ' + data.detail; pgResult.className = 'text-xs mt-1 text-red-400'; testPgBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-red-500 text-sm font-medium text-red-400 whitespace-nowrap'; pgTested = false; }
        })
        .catch(function() { pgResult.classList.remove('hidden'); pgResult.textContent = '✗ 网络错误'; pgResult.className = 'text-xs mt-1 text-red-400'; pgTested = false; })
        .finally(function() { testPgBtn.disabled = false; testPgBtn.textContent = '测试连接'; });
    });
  }

  var testRedisBtn = document.getElementById('test-redis-btn');
  var redisResult = document.getElementById('redis-test-result');
  if (testRedisBtn) {
    testRedisBtn.addEventListener('click', function() {
      var url = redisInput.value;
      if (!url) return;
      testRedisBtn.disabled = true;
      testRedisBtn.textContent = '测试中…';
      redisResult.classList.add('hidden');
      var apiBase = window.__KURA_API_BASE || '/api';
      fetch(apiBase + '/settings/test-redis', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ url: url }) })
        .then(function(resp) { return resp.json(); })
        .then(function(data) {
          redisResult.classList.remove('hidden');
          if (data.ok) { redisResult.textContent = '✓ ' + data.detail; redisResult.className = 'text-xs mt-1 text-green-400'; testRedisBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-green-500 text-sm font-medium text-green-400 whitespace-nowrap'; redisTested = true; }
          else { redisResult.textContent = '✗ ' + data.detail; redisResult.className = 'text-xs mt-1 text-red-400'; testRedisBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-red-500 text-sm font-medium text-red-400 whitespace-nowrap'; redisTested = false; }
        })
        .catch(function() { redisResult.classList.remove('hidden'); redisResult.textContent = '✗ 网络错误'; redisResult.className = 'text-xs mt-1 text-red-400'; redisTested = false; })
        .finally(function() { testRedisBtn.disabled = false; testRedisBtn.textContent = '测试连接'; });
    });
  }

  var saveBtn = document.getElementById('save-btn');
  var saveStatus = document.getElementById('save-status');
  if (saveBtn) {
    saveBtn.addEventListener('click', function() {
      var pgChanged = pgInput && pgInput.value !== origPg;
      var redisChanged = redisInput && redisInput.value !== origRedis;
      if (pgChanged && !pgTested) { saveStatus.classList.remove('hidden'); saveStatus.textContent = '请先测试数据库连接'; saveStatus.className = 'text-sm text-amber-400'; return; }
      if (redisChanged && !redisTested) { saveStatus.classList.remove('hidden'); saveStatus.textContent = '请先测试 Redis 连接'; saveStatus.className = 'text-sm text-amber-400'; return; }
      var updates = {
        site_title: document.getElementById('site_title').value,
        site_description: document.getElementById('site_description').value,
        announcement: document.getElementById('announcement').value,
        head_inject: document.getElementById('head_inject').value,
        maintenance_mode: document.getElementById('maintenance_mode').checked ? 'true' : 'false',
      };
      if (pgChanged && pgTested) updates.database_url = pgInput.value;
      if (redisChanged && redisTested) updates.redis_url = redisInput.value;
      saveBtn.disabled = true;
      saveBtn.textContent = '保存中…';
      saveStatus.classList.add('hidden');
      var apiBase = window.__KURA_API_BASE || '/api';
      fetch(apiBase + '/settings/', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ settings: updates }) })
        .then(function(resp) {
          if (resp.ok) {
            origPg = pgInput ? pgInput.value : '';
            origRedis = redisInput ? redisInput.value : '';
            if (pgModified) pgModified.classList.add('hidden');
            if (redisModified) redisModified.classList.add('hidden');
            pgTested = true;
            redisTested = true;
            saveStatus.classList.remove('hidden');
            saveStatus.textContent = '✓ 已保存';
            saveStatus.className = 'text-sm text-green-400';
            if (testPgBtn) testPgBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] text-sm font-medium text-[var(--text-muted)] hover:bg-[var(--accent-subtle)] transition-colors whitespace-nowrap';
            if (testRedisBtn) testRedisBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] text-sm font-medium text-[var(--text-muted)] hover:bg-[var(--accent-subtle)] transition-colors whitespace-nowrap';
            if (pgResult) pgResult.classList.add('hidden');
            if (redisResult) redisResult.classList.add('hidden');
          } else {
            saveStatus.classList.remove('hidden');
            saveStatus.textContent = '✗ 保存失败';
            saveStatus.className = 'text-sm text-red-400';
          }
        })
        .catch(function() { saveStatus.classList.remove('hidden'); saveStatus.textContent = '✗ 网络错误'; saveStatus.className = 'text-sm text-red-400'; })
        .finally(function() { saveBtn.disabled = false; saveBtn.textContent = '保存设置'; setTimeout(function() { saveStatus.classList.add('hidden'); }, 3000); });
    });
  }
})();
</script>

<!-- ── Password panel scripts ── -->
<script>
  const pwForm = document.getElementById("password-form") as HTMLFormElement;
  const pwError = document.getElementById("pw-error-msg")!;
  const pwSuccess = document.getElementById("pw-success-msg")!;
  const pwSubmitBtn = document.getElementById("pw-submit-btn") as HTMLButtonElement;

  pwForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    pwError.classList.add("hidden");
    pwSuccess.classList.add("hidden");

    const currentPassword = (document.getElementById("current-password") as HTMLInputElement).value;
    const newPassword = (document.getElementById("new-password") as HTMLInputElement).value;
    const confirmPassword = (document.getElementById("confirm-password") as HTMLInputElement).value;

    if (newPassword !== confirmPassword) {
      pwError.textContent = "新密码两次输入不一致";
      pwError.classList.remove("hidden");
      return;
    }

    pwSubmitBtn.disabled = true;
    pwSubmitBtn.textContent = "修改中…";

    try {
      const apiBase = import.meta.env.PUBLIC_API_URL || "/api";
      const resp = await fetch(`${apiBase}/auth/change-password`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ current_password: currentPassword, new_password: newPassword }),
      });

      if (resp.ok) {
        window.location.href = "/login";
      } else {
        const data = await resp.json().catch(() => ({}));
        pwError.textContent = data.detail || "修改失败";
        pwError.classList.remove("hidden");
      }
    } catch {
      pwError.textContent = "网络错误，请稍后重试";
      pwError.classList.remove("hidden");
    } finally {
      pwSubmitBtn.disabled = false;
      pwSubmitBtn.textContent = "修改密码";
    }
  });
</script>
