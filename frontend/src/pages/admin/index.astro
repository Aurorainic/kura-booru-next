            <label class="block text-xs font-medium text-[var(--text-muted)] mb-1">目标标签 ID</label>
            <input type="text" id="merge-target-id" placeholder="b7e4a9f3-…" required class="w-full px-2 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] text-sm font-mono" />
          </div>
          <button type="submit" class="px-4 py-1.5 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] text-sm font-medium hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all">合并</button>
