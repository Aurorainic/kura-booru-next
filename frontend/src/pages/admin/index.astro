---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  fetchPosts, clampPerPage, emptyPostsResponse,
  getRatingColorClass, getRatingLabel, getSourceSiteLabel,
  getThumbUrl, formatFileSize, formatDate,
  fetchAdminTags, fetchAutoRatingRules, fetchTags,
  type Rating, type Tag, type TagCategory, type AutoRatingRule,
} from "@/lib/api";

const isAdmin = Astro.locals.isAdmin ?? false;
const ssrCookie = Astro.locals.ssrCookie;

if (!isAdmin) {
  return Astro.redirect("/login");
}

// Tab state from URL
const tab = Astro.url.searchParams.get("tab") || "posts";
const validTabs = ["posts", "tags", "auto-rating", "settings", "password"];
const activeTab = validTabs.includes(tab) ? tab : "posts";

// ── Posts data ──
const postsPage = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const postsPerPage = 40;
const ratingFilter = (Astro.url.searchParams.get("rating") || "") as Rating | "";

let postsData;
try {
  postsData = await fetchPosts(postsPage, postsPerPage, ratingFilter || undefined, ssrCookie);
} catch {
  postsData = emptyPostsResponse();
}
const { items: posts, total: postsTotal, total_pages: postsTotalPages } = postsData;

function buildPostsPageUrl(p: number, r: string): string {
  const params = new URLSearchParams();
  params.set("tab", "posts");
  if (p > 1) params.set("page", String(p));
  if (r) params.set("rating", r);
  return `/admin?${params.toString()}`;
}

const ratingOptions: { value: string; label: string }[] = [
  { value: "", label: "全部" },
  { value: "safe", label: "公开" },
  { value: "questionable", label: "敏感" },
  { value: "explicit", label: "限制" },
];

// ── Tags data ──
const tagsPage = parseInt(Astro.url.searchParams.get("tpage") || "1");
const tagsPerPage = parseInt(Astro.url.searchParams.get("per_page") || "40");
const tagsCategory = Astro.url.searchParams.get("category") || undefined;
const tagsAiStatus = Astro.url.searchParams.get("ai_status") || undefined;
const tagsQ = Astro.url.searchParams.get("q") || undefined;
const tagsSort = Astro.url.searchParams.get("sort") || "count";

let tagsData = { items: [] as Tag[], total: 0, page: 1, per_page: 40, total_pages: 0 };
try {
  tagsData = await fetchAdminTags(
    { category: tagsCategory as TagCategory | undefined, ai_status: tagsAiStatus, q: tagsQ, sort: tagsSort, page: tagsPage, per_page: tagsPerPage },
    ssrCookie,
  );
} catch {}

// ── Auto-rating data ──
let rules: AutoRatingRule[] = [];
try {
  rules = await fetchAutoRatingRules(ssrCookie);
} catch {}

let autocompleteTags: Tag[] = [];
try {
  const tagsResult = await fetchTags(undefined, "count", 1, 500, ssrCookie);
  autocompleteTags = tagsResult.items;
} catch {}

// ── Settings data ──
const backendUrl = import.meta.env.INTERNAL_API_URL || "http://backend:8000/api";
let settings: Record<string, string> = {};
try {
  const resp = await fetch(`${backendUrl}/settings/`, {
    headers: {
      Accept: "application/json",
      ...(ssrCookie ? { Cookie: ssrCookie } : {}),
    },
  });
  if (resp.ok) {
    const data = await resp.json();
    for (const s of data.settings) {
      settings[s.key] = s.value;
    }
  }
} catch {}
---

<BaseLayout title="管理后台">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-8 py-6">
    <!-- Top-level tabs -->
    <div class="flex items-center gap-1 mb-4 border-b border-[var(--border-color)]">
      <button
        class="admin-top-tab px-5 py-2.5 text-sm font-medium transition-colors duration-[var(--duration-fast)] relative"
        data-group="manage"
        data-active={["posts", "tags", "auto-rating"].includes(activeTab) ? "true" : undefined}
      >
        管理
        <span class="admin-top-tab-indicator absolute bottom-0 left-0 right-0 h-0.5 bg-[var(--accent-color)] rounded-full" style={["posts", "tags", "auto-rating"].includes(activeTab) ? "" : "display:none"}></span>
      </button>
      <button
        class="admin-top-tab px-5 py-2.5 text-sm font-medium transition-colors duration-[var(--duration-fast)] relative"
        data-group="settings"
        data-active={["settings", "password"].includes(activeTab) ? "true" : undefined}
      >
        设置
        <span class="admin-top-tab-indicator absolute bottom-0 left-0 right-0 h-0.5 bg-[var(--accent-color)] rounded-full" style={["settings", "password"].includes(activeTab) ? "" : "display:none"}></span>
      </button>
    </div>

    <!-- Sub-tabs: Manage -->
    <div id="subtabs-manage" class="flex items-center gap-2 mb-6" style={["posts", "tags", "auto-rating"].includes(activeTab) ? "" : "display:none"}>
      <a href="/admin?tab=posts" class={`admin-subtab filter-chip ${activeTab === "posts" ? "active" : ""}`} data-tab="posts">图片</a>
      <a href="/admin?tab=tags" class={`admin-subtab filter-chip ${activeTab === "tags" ? "active" : ""}`} data-tab="tags">标签</a>
      <a href="/admin?tab=auto-rating" class={`admin-subtab filter-chip ${activeTab === "auto-rating" ? "active" : ""}`} data-tab="auto-rating">评级</a>
    </div>

    <!-- Sub-tabs: Settings -->
    <div id="subtabs-settings" class="flex items-center gap-2 mb-6" style={["settings", "password"].includes(activeTab) ? "" : "display:none"}>
      <a href="/admin?tab=settings" class={`admin-subtab filter-chip ${activeTab === "settings" ? "active" : ""}`} data-tab="settings">通用</a>
      <a href="/admin?tab=password" class={`admin-subtab filter-chip ${activeTab === "password" ? "active" : ""}`} data-tab="password">密码</a>
    </div>

    <!-- ═══════════ Panel: Posts ═══════════ -->
    <div id="panel-posts" class="admin-panel" style={activeTab !== "posts" ? "display:none" : ""}>
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-[var(--text-muted)]">{postsTotal} 张插画</p>
        <div class="flex items-center gap-2 text-sm">
          <span class="text-[var(--text-muted)]">评级:</span>
          {ratingOptions.map(opt => (
            <a
              href={buildPostsPageUrl(1, opt.value)}
              class={`filter-chip ${ratingFilter === opt.value ? "active" : ""}`}
            >
              {opt.label}
            </a>
          ))}
        </div>
      </div>

      {posts.length > 0 ? (
        <>
          {/* Desktop table (≥ md) */}
          <div class="hidden md:block overflow-x-auto">
            <table class="w-full text-sm table-fixed">
              <thead>
                <tr class="border-b border-[var(--border-color)] text-left text-[var(--text-muted)]">
                  <th class="py-3 px-2 w-16">预览</th>
                  <th class="py-3 px-2 w-[24%] min-w-[120px]">标题 / ID</th>
                  <th class="py-3 px-2">标签</th>
                  <th class="py-3 px-2 w-20">来源</th>
                  <th class="py-3 px-2 w-20">评级</th>
                  <th class="py-3 px-2 w-32">操作</th>
                </tr>
              </thead>
              <tbody>
                {posts.map((post) => (
                  <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-surface)] transition-colors">
                    <td class="py-2 px-2">
                      <a href={`/posts/${post.id}`}>
                        <img
                          src={post.thumb_key ? getThumbUrl(post) : "/placeholder.svg"}
                          alt=""
                          class="w-12 h-12 object-cover rounded"
                          loading="lazy"
                        />
                      </a>
                    </td>
                    <td class="py-2 px-2 truncate">
                      <a href={`/posts/${post.id}`} class="text-[var(--text-primary)] hover:text-[var(--accent-color)] font-medium">
                        {post.title || post.id.slice(0, 8)}
                      </a>
                    </td>
                    <td class="py-2 px-2">
                      <div class="flex flex-wrap gap-0.5">
                        {(post.tags || []).slice(0, 5).map((tag: any) => (
                          <span class={`tag-${tag.category} text-[0.625rem] px-1 py-0.5 rounded`}>
                            {tag.translation || tag.name}
                          </span>
                        ))}
                        {(post.tags || []).length > 5 && (
                          <span class="text-[0.625rem] text-[var(--text-muted)]">+{(post.tags || []).length - 5}</span>
                        )}
                      </div>
                    </td>
                    <td class="py-2 px-2 text-[var(--text-muted)]">
                      {getSourceSiteLabel(post.source_site)}
                    </td>
                    <td class="py-2 px-2">
                      <span class={`px-2 py-0.5 text-xs font-bold rounded border ${getRatingColorClass(post.rating)}`}>
                        {getRatingLabel(post.rating)}
                      </span>
                    </td>
                    <td class="py-2 px-2">
                      <div class="flex items-center gap-2">
                        <select
                          class="rating-admin-select text-xs px-1.5 py-0.5 rounded border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)]"
                          data-post-id={post.id}
                          data-current-rating={post.rating}
                        >
                          <option value="safe" selected={post.rating === "safe"}>公开</option>
                          <option value="questionable" selected={post.rating === "questionable"}>敏感</option>
                          <option value="explicit" selected={post.rating === "explicit"}>限制</option>
                        </select>
                        <button
                          class="delete-post-btn text-red-400 hover:text-red-300 transition-colors p-1"
                          data-post-id={post.id}
                          title="删除"
                        >
                          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                          </svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {/* Mobile cards (< md) */}
          <div class="md:hidden space-y-3">
            {posts.map((post) => (
              <div class="card p-3" data-post-id={post.id}>
                <div class="flex gap-3">
                  <a href={`/posts/${post.id}`} class="flex-shrink-0">
                    <img
                      src={post.thumb_key ? getThumbUrl(post) : "/placeholder.svg"}
                      alt=""
                      class="w-20 h-20 object-cover rounded"
                      loading="lazy"
                    />
                  </a>
                  <div class="flex-1 min-w-0">
                    <a href={`/posts/${post.id}`} class="text-[var(--text-primary)] hover:text-[var(--accent-color)] font-medium text-sm leading-snug line-clamp-2 break-words">
                      {post.title || post.id.slice(0, 8)}
                    </a>
                    <div class="flex items-center gap-2 mt-1.5 flex-wrap">
                      <span class={`px-1.5 py-0.5 text-[0.625rem] font-bold rounded border ${getRatingColorClass(post.rating)}`}>
                        {getRatingLabel(post.rating)}
                      </span>
                      <span class="text-[0.6875rem] text-[var(--text-muted)]">{getSourceSiteLabel(post.source_site)}</span>
                    </div>
                  </div>
                </div>
                {(post.tags || []).length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-3 pt-3 border-t border-[var(--border-color)]">
                    {(post.tags || []).slice(0, 8).map((tag: any) => (
                      <span class={`tag-${tag.category} text-[0.625rem] px-1.5 py-0.5 rounded`}>
                        {tag.translation || tag.name}
                      </span>
                    ))}
                    {(post.tags || []).length > 8 && (
                      <span class="text-[0.625rem] text-[var(--text-muted)]">+{(post.tags || []).length - 8}</span>
                    )}
                  </div>
                )}
                <div class="flex items-center gap-2 mt-3 pt-3 border-t border-[var(--border-color)]">
                  <label class="text-[0.6875rem] text-[var(--text-muted)] flex-shrink-0">评级</label>
                  <select
                    class="rating-admin-select flex-1 text-xs px-2 py-1 rounded border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)]"
                    data-post-id={post.id}
                    data-current-rating={post.rating}
                  >
                    <option value="safe" selected={post.rating === "safe"}>公开</option>
                    <option value="questionable" selected={post.rating === "questionable"}>敏感</option>
                    <option value="explicit" selected={post.rating === "explicit"}>限制</option>
                  </select>
                  <button
                    class="delete-post-btn text-red-400 hover:text-red-300 transition-colors px-2 py-1 rounded border border-red-500/30 text-xs flex items-center gap-1 flex-shrink-0"
                    data-post-id={post.id}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    删除
                  </button>
                </div>
              </div>
            ))}
          </div>
        </>
      ) : (
        <div class="flex flex-col items-center justify-center py-24 text-[var(--text-muted)]">
          <p class="text-xl mb-2">无符合条件的插画</p>
        </div>
      )}

      {postsTotalPages > 1 && (
        <div class="flex items-center justify-center gap-4 mt-8">
          {postsPage > 1 && (
            <a href={buildPostsPageUrl(postsPage - 1, ratingFilter)} class="px-4 py-2 rounded-[var(--radius-sm)] bg-[var(--bg-surface)] border border-[var(--border-color)] text-sm text-[var(--text-primary)] hover:border-[var(--accent-color)] transition-colors">← 上一页</a>
          )}
          <span class="text-sm text-[var(--text-muted)]">第 {postsPage} / {postsTotalPages} 页</span>
          {postsPage < postsTotalPages && (
            <a href={buildPostsPageUrl(postsPage + 1, ratingFilter)} class="px-4 py-2 rounded-[var(--radius-sm)] bg-[var(--bg-surface)] border border-[var(--border-color)] text-sm text-[var(--text-primary)] hover:border-[var(--accent-color)] transition-colors">下一页 →</a>
          )}
        </div>
      )}
    </div>

    <!-- ═══════════ Panel: Tags ═══════════ -->
    <div id="panel-tags" class="admin-panel" style={activeTab !== "tags" ? "display:none" : ""}>
      <div class="flex items-center justify-between mb-4">
        <p class="text-sm text-[var(--text-muted)]">编辑标签分类、翻译、Danbooru 名称；合并标签；触发 AI 重处理</p>
        <div class="flex gap-2">
          <button id="reprocess-btn" class="px-3 py-1.5 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] text-sm font-medium hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all">处理未处理标签</button>
          <button id="reprocess-force-btn" class="px-3 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] text-[var(--text-muted)] text-sm hover:bg-[var(--bg-primary)] transition-all">全部重处理</button>
        </div>
      </div>

      <div class="card p-4 mb-4">
        <form id="filter-form" class="flex flex-wrap items-end gap-3">
          <div>
            <label class="block text-xs font-medium text-[var(--text-muted)] mb-1">分类</label>
            <select name="category" class="px-2 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] text-sm">
              <option value="">全部</option>
              <option value="artist" selected={tagsCategory === "artist"}>画师</option>
              <option value="character" selected={tagsCategory === "character"}>角色</option>
              <option value="copyright" selected={tagsCategory === "copyright"}>作品</option>
              <option value="general" selected={tagsCategory === "general"}>通用</option>
              <option value="meta" selected={tagsCategory === "meta"}>元信息</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-[var(--text-muted)] mb-1">AI 状态</label>
            <select name="ai_status" class="px-2 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] text-sm">
              <option value="">全部</option>
              <option value="processed" selected={tagsAiStatus === "processed"}>已处理</option>
              <option value="unprocessed" selected={tagsAiStatus === "unprocessed"}>未处理</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-medium text-[var(--text-muted)] mb-1">搜索</label>
            <input type="text" name="q" value={tagsQ || ""} placeholder="标签名前缀…" class="px-2 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] text-sm w-48" />
          </div>
          <div>
            <label class="block text-xs font-medium text-[var(--text-muted)] mb-1">排序</label>
            <select name="sort" class="px-2 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] text-sm">
              <option value="count" selected={tagsSort === "count"}>按数量</option>
              <option value="name" selected={tagsSort === "name"}>按名称</option>
            </select>
          </div>
          <button type="submit" class="px-3 py-1.5 rounded-[var(--radius-md)] bg-[var(--accent-subtle)] text-[var(--accent-color)] text-sm font-medium hover:bg-[var(--accent-hover)] hover:text-[var(--bg-primary)] transition-all">筛选</button>
        </form>
      </div>

      <div class="card overflow-hidden">
        <div class="px-4 py-3 border-b border-[var(--border-color)]">
          <span class="text-sm font-medium text-[var(--text-muted)]">共 {tagsData.total} 个标签</span>
        </div>
        {/* Desktop table (≥ md) */}
        <div class="hidden md:block overflow-x-auto">
          <table class="w-full" id="tags-table">
            <thead>
              <tr class="border-b border-[var(--border-color)]">
                <th class="text-left px-4 py-3 text-xs font-medium text-[var(--text-muted)] w-32">内部 ID</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-[var(--text-muted)]">原始名称</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-[var(--text-muted)]">分类</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-[var(--text-muted)]">Danbooru 名</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-[var(--text-muted)]">中文翻译</th>
                <th class="text-right px-4 py-3 text-xs font-medium text-[var(--text-muted)]">帖子数</th>
                <th class="text-right px-4 py-3 text-xs font-medium text-[var(--text-muted)]">操作</th>
              </tr>
            </thead>
            <tbody>
              {tagsData.items.map((tag) => (
                <tr class="border-b border-[var(--border-color)] hover:bg-[var(--bg-primary)] transition-colors" data-tag-id={tag.id}>
                  <td class="px-4 py-2">
                    <span class="text-[0.625rem] font-mono text-[var(--text-muted)] bg-[var(--bg-primary)] px-1 py-0.5 rounded" title={tag.id}>{tag.id.slice(0, 8)}…</span>
                  </td>
                  <td class="px-4 py-2">
                    <span class="text-[var(--text-primary)] font-medium tag-name-cell">{tag.name}</span>
                  </td>
                  <td class="px-4 py-2">
                    <select class="tag-category-select px-1 py-0.5 rounded text-xs border border-[var(--border-color)] bg-[var(--bg-primary)]" data-tag-id={tag.id} data-field="category">
                      <option value="artist" selected={tag.category === "artist"}>画师</option>
                      <option value="character" selected={tag.category === "character"}>角色</option>
                      <option value="copyright" selected={tag.category === "copyright"}>作品</option>
                      <option value="general" selected={tag.category === "general"}>通用</option>
                      <option value="meta" selected={tag.category === "meta"}>元信息</option>
                    </select>
                  </td>
                  <td class="px-4 py-2">
                    <input type="text" class="tag-danbooru-input px-1 py-0.5 rounded text-xs border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] w-32" value={tag.danbooru_name || ""} placeholder="—" data-tag-id={tag.id} data-field="danbooru_name" />
                  </td>
                  <td class="px-4 py-2">
                    <input type="text" class="tag-translation-input px-1 py-0.5 rounded text-xs border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] w-24" value={tag.translation || ""} placeholder="—" data-tag-id={tag.id} data-field="translation" />
                  </td>
                  <td class="px-4 py-2 text-right">
                    <span class="text-sm text-[var(--text-muted)]">{tag.post_count}</span>
                  </td>
                  <td class="px-4 py-2 text-right">
                    <button class="save-tag-btn px-2 py-1 rounded text-xs bg-[var(--accent-subtle)] text-[var(--accent-color)] hover:bg-[var(--accent-hover)] hover:text-[var(--bg-primary)] transition-all" data-tag-id={tag.id}>保存</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {/* Mobile cards (< md) */}
        <div class="md:hidden p-3 space-y-3">
          {tagsData.items.map((tag) => (
            <div class="card p-3 space-y-2" data-tag-id={tag.id}>
              <div class="flex items-center justify-between gap-2">
                <span class="text-[var(--text-primary)] font-medium tag-name-cell text-sm break-all">{tag.name}</span>
                <span class="text-[0.625rem] font-mono text-[var(--text-muted)] flex-shrink-0">{tag.id.slice(0, 8)}…</span>
              </div>
              <div>
                <label class="block text-[0.6875rem] text-[var(--text-muted)] mb-1">分类</label>
                <select class="tag-category-select w-full px-2 py-1.5 rounded text-xs border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)]" data-tag-id={tag.id} data-field="category">
                  <option value="artist" selected={tag.category === "artist"}>画师</option>
                  <option value="character" selected={tag.category === "character"}>角色</option>
                  <option value="copyright" selected={tag.category === "copyright"}>作品</option>
                  <option value="general" selected={tag.category === "general"}>通用</option>
                  <option value="meta" selected={tag.category === "meta"}>元信息</option>
                </select>
              </div>
              <div>
                <label class="block text-[0.6875rem] text-[var(--text-muted)] mb-1">Danbooru 名</label>
                <input type="text" class="tag-danbooru-input w-full px-2 py-1.5 rounded text-xs border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)]" value={tag.danbooru_name || ""} placeholder="—" data-tag-id={tag.id} data-field="danbooru_name" />
              </div>
              <div>
                <label class="block text-[0.6875rem] text-[var(--text-muted)] mb-1">中文翻译</label>
                <input type="text" class="tag-translation-input w-full px-2 py-1.5 rounded text-xs border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)]" value={tag.translation || ""} placeholder="—" data-tag-id={tag.id} data-field="translation" />
              </div>
              <div class="flex items-center justify-between gap-2 pt-2 border-t border-[var(--border-color)]">
                <span class="text-[0.6875rem] text-[var(--text-muted)]">帖子数 <span class="text-[var(--text-primary)] font-medium tabular-nums">{tag.post_count}</span></span>
                <button class="save-tag-btn px-3 py-1 rounded text-xs bg-[var(--accent-subtle)] text-[var(--accent-color)] hover:bg-[var(--accent-hover)] hover:text-[var(--bg-primary)] transition-all" data-tag-id={tag.id}>保存</button>
              </div>
            </div>
          ))}
        </div>
        {tagsData.total_pages > 1 && (
          <div class="px-4 py-3 border-t border-[var(--border-color)] flex items-center justify-center gap-2 flex-wrap">
            {Array.from({ length: tagsData.total_pages }, (_, i) => i + 1).map((p) => (
              <a
                href={`?tab=tags&tpage=${p}&per_page=${tagsPerPage}&category=${tagsCategory || ""}&ai_status=${tagsAiStatus || ""}&q=${tagsQ || ""}&sort=${tagsSort}`}
                class:list={[
                  "px-3 py-1 rounded text-sm transition-colors",
                  p === tagsData.page ? "bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium" : "text-[var(--text-muted)] hover:bg-[var(--bg-primary)]",
                ]}
              >
                {p}
              </a>
            ))}
          </div>
        )}
      </div>

      <div class="card p-6 mt-6">
        <h2 class="text-sm font-medium text-[var(--text-muted)] mb-4">合并标签</h2>
        <form id="merge-form" class="flex flex-wrap items-end gap-3">
          <div class="flex-1 min-w-[140px]">
