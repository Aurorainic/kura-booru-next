            <div class="relative">
              <input type="text" id="tag-name-input" placeholder="输入标签名…" autocomplete="off" required class="w-full px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)]" />
