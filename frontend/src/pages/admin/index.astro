            <input type="text" id="merge-source-id" placeholder="a3f8c2d1-…" required class="w-full px-2 py-1.5 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] text-sm font-mono" />
