---
import BaseLayout from "@/layouts/BaseLayout.astro";

const isAdmin = Astro.locals.isAdmin ?? false;
if (!isAdmin) {
  return Astro.redirect("/login");
}

// Fetch current settings from backend (SSR)
const cookieHeader = Astro.locals.ssrCookie || "";
const backendUrl = import.meta.env.INTERNAL_API_URL || "http://backend:8000/api";

let settings: Record<string, string> = {};
try {
  const resp = await fetch(`${backendUrl}/settings/`, {
    headers: {
      Accept: "application/json",
      ...(cookieHeader ? { Cookie: cookieHeader } : {}),
    },
  });
  if (resp.ok) {
    const data = await resp.json();
    for (const s of data.settings) {
      settings[s.key] = s.value;
    }
  }
} catch {
  // Backend unreachable
}
---

<BaseLayout title="站点设置">
  <div class="max-w-2xl mx-auto px-6 py-8">
    <h1 class="text-xl font-bold mb-6">站点设置</h1>

    <!-- General settings card -->
    <div class="card p-6 rounded-[var(--radius-xl)] mb-6">
      <h2 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-4">通用</h2>
      <form id="settings-form" class="space-y-4">
        <div>
          <label for="site_title" class="block text-sm font-medium text-[var(--text-muted)] mb-1">站点标题</label>
          <input
            type="text"
            id="site_title"
            name="site_title"
            value={settings.site_title || "Kura Booru"}
            class="w-full px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)]"
          />
        </div>
        <div>
          <label for="site_description" class="block text-sm font-medium text-[var(--text-muted)] mb-1">站点描述</label>
          <input
            type="text"
            id="site_description"
            name="site_description"
            value={settings.site_description || "个人动漫插画收藏与展示平台"}
            class="w-full px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)]"
          />
        </div>
        <div>
          <label for="announcement" class="block text-sm font-medium text-[var(--text-muted)] mb-1">公告内容</label>
          <textarea
            id="announcement"
            name="announcement"
            rows="4"
            class="w-full px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] resize-y"
          >{settings.announcement || ""}</textarea>
          <p class="text-xs text-[var(--text-muted)] mt-1">支持 **加粗**、*斜体*、`代码`、[链接](url)</p>
        </div>
        <div>
          <label for="head_inject" class="block text-sm font-medium text-[var(--text-muted)] mb-1">Head 注入</label>
          <textarea
            id="head_inject"
            name="head_inject"
            rows="6"
            class="w-full px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] resize-y font-mono text-sm"
          >{settings.head_inject || ""}</textarea>
          <p class="text-xs text-[var(--text-muted)] mt-1">用于注入分析脚本等 HTML 内容</p>
        </div>
      </form>
    </div>

    <!-- Infrastructure settings card -->
    <div class="card p-6 rounded-[var(--radius-xl)] mb-6">
      <h2 class="text-sm font-semibold text-[var(--text-muted)] uppercase tracking-wider mb-4">基础设施</h2>
      <div class="space-y-4">
        <div>
          <div class="flex items-center justify-between mb-1">
            <label for="database_url" class="block text-sm font-medium text-[var(--text-muted)]">数据库 URL</label>
            <span id="pg-modified" class="text-xs text-amber-400 hidden">已修改</span>
          </div>
          <div class="flex gap-2">
            <input
              type="text"
              id="database_url"
              name="database_url"
              value={settings.database_url || ""}
              class="flex-1 px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] font-mono text-sm"
            />
            <button
              type="button"
              id="test-pg-btn"
              class="px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] text-sm font-medium text-[var(--text-muted)] hover:bg-[var(--accent-subtle)] transition-colors whitespace-nowrap"
            >
              测试连接
            </button>
          </div>
          <p id="pg-test-result" class="text-xs mt-1 hidden"></p>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <label for="redis_url" class="block text-sm font-medium text-[var(--text-muted)]">Redis URL</label>
            <span id="redis-modified" class="text-xs text-amber-400 hidden">已修改</span>
          </div>
          <div class="flex gap-2">
            <input
              type="text"
              id="redis_url"
              name="redis_url"
              value={settings.redis_url || ""}
              class="flex-1 px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] bg-[var(--bg-primary)] text-[var(--text-primary)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)] font-mono text-sm"
            />
            <button
              type="button"
              id="test-redis-btn"
              class="px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] text-sm font-medium text-[var(--text-muted)] hover:bg-[var(--accent-subtle)] transition-colors whitespace-nowrap"
            >
              测试连接
            </button>
          </div>
          <p id="redis-test-result" class="text-xs mt-1 hidden"></p>
        </div>
        <p class="text-xs text-[var(--text-muted)]">⚠️ 修改后下次重启生效</p>
      </div>
    </div>

    <!-- Save button -->
    <div class="flex items-center gap-3">
      <button
        type="button"
        id="save-btn"
        class="px-6 py-2 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all duration-[var(--duration-fast)]"
      >
        保存设置
      </button>
      <span id="save-status" class="text-sm text-[var(--text-muted)] hidden"></span>
    </div>

    <div class="mt-6">
      <a href="/admin/posts" class="text-sm text-[var(--text-muted)] hover:text-[var(--accent-color)] transition-colors">
        ← 返回管理
      </a>
    </div>
  </div>
</BaseLayout>

<script is:inline>
(function() {
  // Original values for infrastructure fields
  var origPg = document.getElementById('database_url').value;
  var origRedis = document.getElementById('redis_url').value;

  // Connectivity test state
  var pgTested = false;
  var redisTested = false;

  // ── Infrastructure field change detection ──────────────────────────
  var pgInput = document.getElementById('database_url');
  var redisInput = document.getElementById('redis_url');
  var pgModified = document.getElementById('pg-modified');
  var redisModified = document.getElementById('redis-modified');

  function checkInfraChanges() {
    var pgChanged = pgInput.value !== origPg;
    var redisChanged = redisInput.value !== origRedis;

    if (pgChanged) {
      pgModified.classList.remove('hidden');
      pgTested = false; // must re-test after change
    } else {
      pgModified.classList.add('hidden');
      pgTested = true; // original value is implicitly "tested"
    }

    if (redisChanged) {
      redisModified.classList.remove('hidden');
      redisTested = false;
    } else {
      redisModified.classList.add('hidden');
      redisTested = true;
    }
  }

  pgInput.addEventListener('input', checkInfraChanges);
  redisInput.addEventListener('input', checkInfraChanges);

  // ── Test PG connectivity ───────────────────────────────────────────
  var testPgBtn = document.getElementById('test-pg-btn');
  var pgResult = document.getElementById('pg-test-result');

  testPgBtn.addEventListener('click', function() {
    var url = pgInput.value;
    if (!url) return;

    testPgBtn.disabled = true;
    testPgBtn.textContent = '测试中…';
    pgResult.classList.add('hidden');

    var apiBase = window.__KURA_API_BASE || '/api';
    fetch(apiBase + '/settings/test-pg', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url: url })
    })
    .then(function(resp) { return resp.json(); })
    .then(function(data) {
      pgResult.classList.remove('hidden');
      if (data.ok) {
        pgResult.textContent = '✓ ' + data.detail;
        pgResult.className = 'text-xs mt-1 text-green-400';
        testPgBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-green-500 text-sm font-medium text-green-400 whitespace-nowrap';
        pgTested = true;
      } else {
        pgResult.textContent = '✗ ' + data.detail;
        pgResult.className = 'text-xs mt-1 text-red-400';
        testPgBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-red-500 text-sm font-medium text-red-400 whitespace-nowrap';
        pgTested = false;
      }
    })
    .catch(function() {
      pgResult.classList.remove('hidden');
      pgResult.textContent = '✗ 网络错误';
      pgResult.className = 'text-xs mt-1 text-red-400';
      pgTested = false;
    })
    .finally(function() {
      testPgBtn.disabled = false;
      testPgBtn.textContent = '测试连接';
    });
  });

  // ── Test Redis connectivity ────────────────────────────────────────
  var testRedisBtn = document.getElementById('test-redis-btn');
  var redisResult = document.getElementById('redis-test-result');

  testRedisBtn.addEventListener('click', function() {
    var url = redisInput.value;
    if (!url) return;

    testRedisBtn.disabled = true;
    testRedisBtn.textContent = '测试中…';
    redisResult.classList.add('hidden');

    var apiBase = window.__KURA_API_BASE || '/api';
    fetch(apiBase + '/settings/test-redis', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url: url })
    })
    .then(function(resp) { return resp.json(); })
    .then(function(data) {
      redisResult.classList.remove('hidden');
      if (data.ok) {
        redisResult.textContent = '✓ ' + data.detail;
        redisResult.className = 'text-xs mt-1 text-green-400';
        testRedisBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-green-500 text-sm font-medium text-green-400 whitespace-nowrap';
        redisTested = true;
      } else {
        redisResult.textContent = '✗ ' + data.detail;
        redisResult.className = 'text-xs mt-1 text-red-400';
        testRedisBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-red-500 text-sm font-medium text-red-400 whitespace-nowrap';
        redisTested = false;
      }
    })
    .catch(function() {
      redisResult.classList.remove('hidden');
      redisResult.textContent = '✗ 网络错误';
      redisResult.className = 'text-xs mt-1 text-red-400';
      redisTested = false;
    })
    .finally(function() {
      testRedisBtn.disabled = false;
      testRedisBtn.textContent = '测试连接';
    });
  });

  // ── Save settings ──────────────────────────────────────────────────
  var saveBtn = document.getElementById('save-btn');
  var saveStatus = document.getElementById('save-status');

  saveBtn.addEventListener('click', function() {
    // Check infrastructure fields: if modified, must be tested first
    var pgChanged = pgInput.value !== origPg;
    var redisChanged = redisInput.value !== origRedis;

    if (pgChanged && !pgTested) {
      saveStatus.classList.remove('hidden');
      saveStatus.textContent = '请先测试数据库连接';
      saveStatus.className = 'text-sm text-amber-400';
      return;
    }
    if (redisChanged && !redisTested) {
      saveStatus.classList.remove('hidden');
      saveStatus.textContent = '请先测试 Redis 连接';
      saveStatus.className = 'text-sm text-amber-400';
      return;
    }

    // Build update payload
    var updates = {
      site_title: document.getElementById('site_title').value,
      site_description: document.getElementById('site_description').value,
      announcement: document.getElementById('announcement').value,
      head_inject: document.getElementById('head_inject').value
    };

    // Only include infrastructure fields if they were changed AND tested
    if (pgChanged && pgTested) {
      updates.database_url = pgInput.value;
    }
    if (redisChanged && redisTested) {
      updates.redis_url = redisInput.value;
    }

    saveBtn.disabled = true;
    saveBtn.textContent = '保存中…';
    saveStatus.classList.add('hidden');

    var apiBase = window.__KURA_API_BASE || '/api';
    fetch(apiBase + '/settings/', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ settings: updates })
    })
    .then(function(resp) {
      if (resp.ok) {
        // Update original values for infrastructure fields
        origPg = pgInput.value;
        origRedis = redisInput.value;
        checkInfraChanges();

        saveStatus.classList.remove('hidden');
        saveStatus.textContent = '✓ 已保存';
        saveStatus.className = 'text-sm text-green-400';

        // Reset test button styles
        testPgBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] text-sm font-medium text-[var(--text-muted)] hover:bg-[var(--accent-subtle)] transition-colors whitespace-nowrap';
        testRedisBtn.className = 'px-3 py-2 rounded-[var(--radius-md)] border border-[var(--border-color)] text-sm font-medium text-[var(--text-muted)] hover:bg-[var(--accent-subtle)] transition-colors whitespace-nowrap';
        pgResult.classList.add('hidden');
        redisResult.classList.add('hidden');
      } else {
        saveStatus.classList.remove('hidden');
        saveStatus.textContent = '✗ 保存失败';
        saveStatus.className = 'text-sm text-red-400';
      }
    })
    .catch(function() {
      saveStatus.classList.remove('hidden');
      saveStatus.textContent = '✗ 网络错误';
      saveStatus.className = 'text-sm text-red-400';
    })
    .finally(function() {
      saveBtn.disabled = false;
      saveBtn.textContent = '保存设置';
      // Auto-hide status after 3s
      setTimeout(function() {
        saveStatus.classList.add('hidden');
      }, 3000);
    });
  });
})();
</script>
