---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
  fetchRandomPost,
  getPreviewUrl,
  getRatingColorClass,
  getRatingLabel,
  getSourceSiteLabel,
  type Post,
} from "@/lib/api";

const ssrCookie = Astro.locals.ssrCookie;

let post: Post | null = null;
try {
  post = await fetchRandomPost(ssrCookie);
} catch {}
---

<BaseLayout title="随机发现">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-8 py-6">
    <div class="flex flex-col items-center gap-6">

      <!-- Title -->
      <h1 class="gradient-text text-center" style="font-size: clamp(1.25rem, 2vw, 1.75rem); font-weight: 700; letter-spacing: -0.02em;">
        随机发现
      </h1>

      <!-- Image frame -->
      <div id="random-frame" class="relative w-full max-w-[680px] rounded-[var(--radius-md)] overflow-hidden bg-[var(--bg-surface)] border border-[var(--border-color)] shadow-lg transition-opacity duration-300">
        {post ? (
          <a id="random-link" href={`/posts/${post.id}`} class="block">
            <img
              id="random-img"
              src={getPreviewUrl(post)}
              alt={post.title || "随机插画"}
              class="w-full h-auto object-contain transition-opacity duration-300"
              loading="eager"
            />
          </a>
        ) : (
          <div class="flex items-center justify-center py-24 text-[var(--text-muted)]">
            <p>暂无图片</p>
          </div>
        )}
      </div>

      <!-- Info area -->
      {post && (
        <div id="random-info" class="w-full max-w-[680px] flex flex-col gap-2 text-center">
          <div class="flex items-center justify-center gap-2 text-sm">
            <span id="random-title" class="font-medium text-[var(--text-primary)]">{post.title || "—"}</span>
            <span id="random-rating" class={`px-2 py-0.5 text-xs font-bold rounded border ${getRatingColorClass(post.rating)}`}>
              {getRatingLabel(post.rating)}
            </span>
          </div>
          <div id="random-source" class="text-xs text-[var(--text-muted)]">
            {getSourceSiteLabel(post.source_site)} · {post.width}×{post.height}
          </div>
          <div id="random-tags" class="flex items-center justify-center gap-1.5 flex-wrap text-xs">
            {post.tags.slice(0, 8).map((tag) => (
              <a href={`/tags?q=${tag.name}`} class="px-1.5 py-0.5 rounded bg-[var(--accent-subtle)] text-[var(--accent-color)] hover:bg-[var(--accent-color)] hover:text-[var(--bg-primary)] transition-colors">
                {tag.name}
              </a>
            ))}
            {post.tags.length > 8 && (
              <span class="text-[var(--text-muted)]">+{post.tags.length - 8}</span>
            )}
          </div>
        </div>
      )}

      <!-- Shuffle button -->
      <button
        id="shuffle-btn"
        type="button"
        class="flex items-center justify-center gap-2 px-6 py-3 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium text-sm hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all duration-[var(--duration-fast)] shadow-md"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"></path>
          <path d="m18 2 4 4-4 4"></path>
          <path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"></path>
          <path d="M22 18h-5.9a5.5 5.5 0 0 1-3.8-2.6l-0.5-.8"></path>
          <path d="m18 14 4 4-4 4"></path>
        </svg>
        随机刷新
      </button>

      <!-- Keyboard hint -->
      <p class="text-xs text-[var(--text-muted)]">按 <kbd class="px-1.5 py-0.5 rounded border border-[var(--border-color)] bg-[var(--bg-surface)] font-mono">Space</kbd> 也可刷新</p>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ s3Base: import.meta.env.PUBLIC_S3_EXTERNAL_URL || "/i" }}>
  window.__KURA_S3_BASE = s3Base;
</script>

<script is:inline>
(function() {
  var btn = document.getElementById('shuffle-btn');
  var frame = document.getElementById('random-frame');
  var img = document.getElementById('random-img');
  var link = document.getElementById('random-link');
  var titleEl = document.getElementById('random-title');
  var ratingEl = document.getElementById('random-rating');
  var sourceEl = document.getElementById('random-source');
  var tagsEl = document.getElementById('random-tags');
  var apiBase = window.__KURA_API_BASE || '/api';
  var s3Base = window.__KURA_S3_BASE || '/i';

  if (!btn || !img) return;

  var loading = false;

  function shuffle() {
    if (loading) return;
    loading = true;
    btn.disabled = true;
    btn.textContent = '加载中…';

    // Fade out
    img.style.opacity = '0.3';

    fetch(apiBase + '/posts/random', {credentials: 'include'})
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(post) {
        // Update image
        img.src = s3Base + '/' + post.preview_key;
        img.alt = post.title || '随机插画';
        link.href = '/posts/' + post.id;

        // Update info
        if (titleEl) titleEl.textContent = post.title || '—';

        if (ratingEl) {
          var labelMap = {safe: '公开', questionable: '敏感', explicit: '限制'};
          var classMap = {safe: 'rating-safe', questionable: 'rating-questionable', explicit: 'rating-explicit'};
          ratingEl.textContent = labelMap[post.rating] || post.rating;
          ratingEl.className = 'px-2 py-0.5 text-xs font-bold rounded border ' + (classMap[post.rating] || '');
        }

        if (sourceEl) {
          var siteMap = {pixiv: 'Pixiv', twitter: 'Twitter/X', danbooru: 'Danbooru'};
          sourceEl.textContent = (siteMap[post.source_site] || post.source_site) + ' · ' + post.width + '×' + post.height;
        }

        if (tagsEl) {
          var html = '';
          var tags = post.tags || [];
          var max = Math.min(tags.length, 8);
          for (var i = 0; i < max; i++) {
            html += '<a href="/tags?q=' + encodeURIComponent(tags[i].name) + '" class="px-1.5 py-0.5 rounded bg-[var(--accent-subtle)] text-[var(--accent-color)] hover:bg-[var(--accent-color)] hover:text-[var(--bg-primary)] transition-colors">' + tags[i].name + '</a>';
          }
          if (tags.length > 8) {
            html += '<span class="text-[var(--text-muted)]">+' + (tags.length - 8) + '</span>';
          }
          tagsEl.innerHTML = html;
        }

        // Fade in
        img.onload = function() {
          img.style.opacity = '1';
          loading = false;
          btn.disabled = false;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"></path><path d="m18 2 4 4-4 4"></path><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"></path><path d="M22 18h-5.9a5.5 5.5 0 0 1-3.8-2.6l-0.5-.8"></path><path d="m18 14 4 4-4 4"></path></svg> 随机刷新';
        };
        img.onerror = function() {
          img.style.opacity = '1';
          loading = false;
          btn.disabled = false;
          btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"></path><path d="m18 2 4 4-4 4"></path><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"></path><path d="M22 18h-5.9a5.5 5.5 0 0 1-3.8-2.6l-0.5-.8"></path><path d="m18 14 4 4-4 4"></path></svg> 随机刷新';
        };
      })
      .catch(function() {
        img.style.opacity = '1';
        loading = false;
        btn.disabled = false;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l6.1-8.6c.7-1.1 2-1.7 3.3-1.7H22"></path><path d="m18 2 4 4-4 4"></path><path d="M2 6h1.9c1.5 0 2.9.9 3.6 2.2"></path><path d="M22 18h-5.9a5.5 5.5 0 0 1-3.8-2.6l-0.5-.8"></path><path d="m18 14 4 4-4 4"></path></svg> 随机刷新';
      });
  }

  btn.addEventListener('click', shuffle);

  // Space key shortcut
  document.addEventListener('keydown', function(e) {
    if (e.code === 'Space' && e.target === document.body) {
      e.preventDefault();
      shuffle();
    }
  });
})();
</script>
