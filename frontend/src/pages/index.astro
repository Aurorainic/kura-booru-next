---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.tsx";
import PhotoAlbumClient from "@/components/PhotoAlbum.tsx";
import { fetchPosts } from "@/lib/api";

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const perPage = Math.min(100, Math.max(1, parseInt(Astro.url.searchParams.get("per_page") || "40")));

let data;
try {
  data = await fetchPosts(page, perPage);
} catch {
  data = { items: [], total: 0, page: 1, per_page: 40, total_pages: 0 };
}

const { items: posts, total, total_pages } = data;

function buildPageUrl(p: number, pp: number): string {
  const params = new URLSearchParams();
  if (p > 1) params.set("page", String(p));
  if (pp !== 40) params.set("per_page", String(pp));
  const qs = params.toString();
  return qs ? `/?${qs}` : "/";
}
---

<BaseLayout title={page > 1 ? `Page ${page}` : undefined} description={`Browse anime illustrations — ${total} posts`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-[var(--text-primary)]">
          <span class="gradient-text">Gallery</span>
        </h1>
        <p class="text-sm text-[var(--text-muted)] mt-1">{total} illustrations</p>
      </div>
    </div>

    <!-- Masonry grid -->
    {posts.length > 0 ? (
      <PhotoAlbumClient client:visible posts={posts} />
    ) : (
      <div class="flex flex-col items-center justify-center py-24 text-[var(--text-muted)]">
        <p class="text-xl mb-2">No illustrations yet</p>
        <p class="text-sm">Send images via the Telegram bot to get started</p>
      </div>
    )}

    <!-- Pagination -->
    {total_pages > 0 && (
      <Pagination
        client:visible
        currentPage={page}
        totalPages={total_pages}
        perPage={perPage}
        buildUrl={buildPageUrl}
      />
    )}
  </div>
</BaseLayout>