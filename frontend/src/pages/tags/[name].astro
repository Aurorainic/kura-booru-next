---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.tsx";
import PhotoAlbumGrid from "@/components/PhotoAlbum.astro";
import { fetchSearch, fetchTag, getTagCategoryColor, getTagCategoryLabel, clampPerPage, emptyPostsResponse, type TagCategory } from "@/lib/api";

const tagName = decodeURIComponent(Astro.params.name!);
const ssrCookie = Astro.locals.ssrCookie;
const isAdmin = Astro.locals.isAdmin ?? false;

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const perPage = clampPerPage(parseInt(Astro.url.searchParams.get("per_page") || "40"));

// Search for posts with this tag
let data;
try {
  data = await fetchSearch(tagName, page, perPage, ssrCookie);
} catch {
  data = emptyPostsResponse();
}

const { items: posts, total, total_pages } = data;

// Resolve tag category via the single-tag endpoint
let tagCategory: TagCategory | null = null;
try {
  const tag = await fetchTag(tagName, ssrCookie);
  tagCategory = tag.category;
} catch {
  // Tag not found or not visible — category is best-effort
}

function buildPageUrl(p: number, pp: number): string {
  const params = new URLSearchParams();
  if (p > 1) params.set("page", String(p));
  if (pp !== 40) params.set("per_page", String(pp));
  const qs = params.toString();
  return qs ? `/tags/${encodeURIComponent(tagName)}?${qs}` : `/tags/${encodeURIComponent(tagName)}`;
}
---

<BaseLayout title={`标签：${tagName}`} description={`共有 ${total} 张插画使用了标签 "${tagName}"`}>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-8 py-6">
    <!-- Back link -->
    <a
      href="/tags"
      class="inline-flex items-center gap-1 text-sm text-[var(--text-muted)] hover:text-[var(--accent-color)] transition-colors mb-4 hover:translate-x-[-3px]"
    >
      ← 全部标签
    </a>

    <!-- Tag header with category badge -->
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-2xl font-bold text-[var(--text-primary)]">
        <span class="gradient-text">{tagName}</span>
      </h1>
      {tagCategory && (
        <span class={`text-xs px-2.5 py-1 rounded-md border font-medium ${getTagCategoryColor(tagCategory)}`}>
          {getTagCategoryLabel(tagCategory)}
        </span>
      )}
    </div>
    <p class="text-sm text-[var(--text-muted)] mb-6">
      {total > 0
        ? `${total} 张插画使用了标签 "${tagName}"`
        : `暂无使用标签 "${tagName}" 的插画`}
    </p>

    <!-- Masonry grid -->
    {posts.length > 0 ? (
      <PhotoAlbumGrid posts={posts} isAdmin={isAdmin} />
    ) : (
      <div class="flex flex-col items-center justify-center py-24 text-[var(--text-muted)]">
        <p class="text-xl mb-2">未找到相关插画</p>
        <p class="text-sm">暂无使用标签 "{tagName}" 的作品</p>
      </div>
    )}

    <!-- Pagination -->
    {total_pages > 0 && (
      <Pagination
        client:visible
        currentPage={page}
        totalPages={total_pages}
        perPage={perPage}
        buildUrl={buildPageUrl}
      />
    )}
  </div>
</BaseLayout>