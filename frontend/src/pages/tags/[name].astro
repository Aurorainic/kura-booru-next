---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Pagination from "@/components/Pagination.tsx";
import PhotoAlbumClient from "@/components/PhotoAlbum.tsx";
import { fetchSearch, fetchTags, getTagCategoryColor, getTagCategoryLabel, type TagCategory, type Tag } from "@/lib/api";

const tagName = decodeURIComponent(Astro.params.name!);

const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const perPage = Math.min(100, Math.max(1, parseInt(Astro.url.searchParams.get("per_page") || "40")));

// Search for posts with this tag
let data;
try {
  data = await fetchSearch(tagName, page, perPage);
} catch {
  data = { items: [], total: 0, page: 1, per_page: 40, total_pages: 0 };
}

const { items: posts, total, total_pages } = data;

// Try to resolve tag category by searching for the tag name
let tagCategory: TagCategory | null = null;
try {
  const tagsData = await fetchTags(undefined, "name", 1, 1000);
  const matchedTag = tagsData.items.find((t: Tag) => t.name === tagName);
  if (matchedTag) {
    tagCategory = matchedTag.category;
  }
} catch {
  // Category lookup is best-effort
}

function buildPageUrl(p: number, pp: number): string {
  const params = new URLSearchParams();
  if (p > 1) params.set("page", String(p));
  if (pp !== 40) params.set("per_page", String(pp));
  const qs = params.toString();
  return qs ? `/tags/${encodeURIComponent(tagName)}?${qs}` : `/tags/${encodeURIComponent(tagName)}`;
}
---

<BaseLayout title={`Tag: ${tagName}`} description={`${total} illustrations tagged with "${tagName}"`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <!-- Back link -->
    <a
      href="/tags"
      class="inline-flex items-center gap-1 text-sm text-[var(--text-muted)] hover:text-[var(--color-cyan-accent-start)] transition-colors mb-4"
    >
      ← All tags
    </a>

    <!-- Tag header with category badge -->
    <div class="flex items-center gap-3 mb-2">
      <h1 class="text-2xl font-bold text-[var(--text-primary)]">
        <span class="gradient-text">{tagName}</span>
      </h1>
      {tagCategory && (
        <span class={`text-xs px-2.5 py-1 rounded-md border font-medium ${getTagCategoryColor(tagCategory)}`}>
          {getTagCategoryLabel(tagCategory)}
        </span>
      )}
    </div>
    <p class="text-sm text-[var(--text-muted)] mb-6">
      {total > 0
        ? `${total} illustration${total !== 1 ? "s" : ""} tagged with "${tagName}"`
        : `No illustrations tagged with "${tagName}"`}
    </p>

    <!-- Masonry grid -->
    {posts.length > 0 ? (
      <PhotoAlbumClient client:visible posts={posts} />
    ) : (
      <div class="flex flex-col items-center justify-center py-24 text-[var(--text-muted)]">
        <p class="text-xl mb-2">No illustrations found</p>
        <p class="text-sm">No posts are tagged with "{tagName}"</p>
      </div>
    )}

    <!-- Pagination -->
    {total_pages > 0 && (
      <Pagination
        client:visible
        currentPage={page}
        totalPages={total_pages}
        perPage={perPage}
        buildUrl={buildPageUrl}
      />
    )}
  </div>
</BaseLayout>