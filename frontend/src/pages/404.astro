---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 — 页面未找到">
  <div class="flex flex-col items-center justify-center min-h-[60vh] gap-4 relative overflow-hidden">
    <!-- Decorative glow circles -->
    <div class="absolute w-[300px] h-[300px] rounded-full -top-20 -left-20 pointer-events-none" style="background: oklch(72% 0.12 175 / 0.06); filter: blur(80px); animation: glowPulse 6s ease-in-out infinite;"></div>
    <div class="absolute w-[250px] h-[250px] rounded-full top-1/3 -right-10 pointer-events-none" style="background: oklch(72% 0.12 175 / 0.06); filter: blur(80px); animation: glowPulse 6s ease-in-out 2s infinite;"></div>
    <div class="absolute w-[200px] h-[200px] rounded-full bottom-10 left-1/4 pointer-events-none" style="background: oklch(72% 0.12 175 / 0.06); filter: blur(80px); animation: glowPulse 6s ease-in-out 4s infinite;"></div>

    <div class="gradient-text" style="font-size: clamp(6rem, 18vw, 12rem); font-weight: 800; line-height: 1; letter-spacing: -0.04em; animation: numberIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;">
      404
    </div>
    <p class="text-[var(--text-primary)] font-semibold" style="font-size: clamp(1.25rem, 3vw, 1.75rem); animation: slideUp var(--duration-slow) var(--ease-out) 0.1s both;">页面未找到</p>
    <p class="text-[var(--text-muted)] text-[0.9375rem] max-w-[360px] text-center" style="animation: slideUp var(--duration-slow) var(--ease-out) 0.2s both;">你访问的页面可能已被移除、重命名，或暂时不可用</p>
    <a
      href="/"
      class="mt-4 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium inline-flex items-center gap-2 hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all duration-[var(--duration-fast)]"
      style="animation: slideUp var(--duration-slow) var(--ease-out) 0.3s both;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.25-8.25M2.25 12l8.25 8.25M2.25 12H21" />
      </svg>
      返回首页
    </a>
  </div>
</BaseLayout>
