---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 — 页面未找到">
  <div class="flex flex-col items-center justify-center min-h-[60vh] gap-4">
    <div class="text-6xl font-bold gradient-text">404</div>
    <p class="text-lg text-[var(--text-muted)]">页面未找到</p>
    <a href="/" class="mt-4 px-4 py-2 rounded-lg gradient-bg text-white font-medium hover:opacity-90 transition-opacity">
      返回首页
    </a>
  </div>
</BaseLayout>