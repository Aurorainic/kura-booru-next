---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchBar from "@/components/SearchBar.tsx";
import Pagination from "@/components/Pagination.tsx";
import PhotoAlbumGrid from "@/components/PhotoAlbum.astro";
import { fetchSearch, clampPerPage } from "@/lib/api";

const isAdmin = Astro.locals.isAdmin ?? false;
const ssrCookie = Astro.locals.ssrCookie;

const query = Astro.url.searchParams.get("q") || "";
const page = Math.max(1, parseInt(Astro.url.searchParams.get("page") || "1"));
const perPage = clampPerPage(parseInt(Astro.url.searchParams.get("per_page") || "40"));

let posts: any[] = [];
let total = 0;
let total_pages = 0;

if (query) {
  try {
    const data = await fetchSearch(query, page, perPage, ssrCookie);
    posts = data.items;
    total = data.total;
    total_pages = data.total_pages;
  } catch {
    // Keep empty results
  }
}
---

<BaseLayout title={query ? `搜索：${query}` : "搜索"} description={query ? `"${query}" 的搜索结果` : "按标签搜索插画"}>
  <div class="max-w-[1400px] mx-auto px-6 lg:px-8 py-6">
    <!-- Search header -->
    <div class="mb-8 text-center" style="animation: searchIn var(--duration-slow) var(--ease-out);">
      <h1 class="gradient-text mb-6" style="font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.2;">
        搜索
      </h1>
      <SearchBar
        client:load
        initialQuery={query}
        onSearch={(q: string) => {
          window.location.href = `/search?q=${encodeURIComponent(q)}`;
        }}
      />
    </div>

    <!-- Empty state: no query -->
    {!query && (
      <div class="flex flex-col items-center justify-center py-24 text-[var(--text-muted)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mb-4 text-[var(--border-color)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <p class="text-lg font-semibold mb-1">按标签搜索</p>
        <p class="text-sm max-w-[320px] text-center">使用 <kbd class="px-1.5 py-0.5 rounded-[var(--radius-sm)] bg-[var(--bg-surface)] border border-[var(--border-color)] text-[var(--text-primary)] font-mono text-xs">+</kbd> 组合标签，<kbd class="px-1.5 py-0.5 rounded-[var(--radius-sm)] bg-[var(--bg-surface)] border border-[var(--border-color)] text-[var(--text-primary)] font-mono text-xs">-</kbd> 排除。例如：landscape + sunset - night{isAdmin && "，或用 rating:safe / rating:q / rating:e 按评级筛选"}</p>
      </div>
    )}

    {/* Results summary */}
    {query && (
      <div class="mb-4">
        <p class="text-sm text-[var(--text-muted)]">
          {total > 0 ? (
            <>
              找到 <span class="gradient-text font-medium">{total}</span> 个结果，关键词 "<span class="font-medium text-[var(--text-primary)]">{query}</span>"
            </>
          ) : (
            <>
              未找到 "<span class="font-medium text-[var(--text-primary)]">{query}</span>" 的结果
            </>
          )}
        </p>
      </div>
    )}

    {/* No results state */}
    {query && posts.length === 0 && (
      <div class="flex flex-col items-center justify-center py-20 text-[var(--text-muted)]">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mb-4 text-[var(--border-color)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
        </svg>
        <p class="text-lg font-semibold mb-1">未找到结果</p>
        <p class="text-sm mb-4">尝试其他标签或减少过滤条件</p>
        <a
          href="/search"
          class="px-4 py-2 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium text-sm hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all duration-[var(--duration-fast)]"
        >
          清除搜索
        </a>
      </div>
    )}

    <!-- Results masonry grid -->
    {posts.length > 0 && (
      <PhotoAlbumGrid posts={posts} isAdmin={isAdmin} />
    )}

    <!-- Pagination -->
    {total_pages > 1 && (
      <Pagination
        client:visible
        currentPage={page}
        totalPages={total_pages}
        perPage={perPage}
      />
    )}
  </div>
</BaseLayout>
