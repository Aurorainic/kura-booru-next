---
import BaseLayout from "@/layouts/BaseLayout.astro";

const isAdmin = Astro.locals.isAdmin ?? false;
---

<BaseLayout title="维护中">
  <div class="flex flex-col items-center justify-center min-h-[60vh] gap-4 relative overflow-hidden">
    <!-- Decorative glow circles -->
    <div class="absolute w-[300px] h-[300px] rounded-full -top-20 -left-20 pointer-events-none" style="background: oklch(72% 0.12 var(--accent-hue) / 0.06); filter: blur(80px); animation: glowPulse 6s ease-in-out infinite;"></div>
    <div class="absolute w-[250px] h-[250px] rounded-full top-1/3 -right-10 pointer-events-none" style="background: oklch(72% 0.12 var(--accent-hue) / 0.06); filter: blur(80px); animation: glowPulse 6s ease-in-out 2s infinite;"></div>

    <!-- Wrench icon -->
    <div class="w-16 h-16 rounded-[var(--radius-lg)] bg-[var(--accent-subtle)] flex items-center justify-center" style="animation: cardIn var(--duration-slow) var(--ease-out);">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[var(--accent-color)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.633 1.207-.766M11.42 15.17l-4.655 5.653a2.048 2.048 0 0 1-3.232 0l-1.348-1.638a2.048 2.048 0 0 1 0-3.232l5.653-4.655m6.518 6.518-1.638-1.348a2.048 2.048 0 0 0-3.232 0l-5.653 4.655m6.518 6.518a2.048 2.048 0 0 0 3.232 0l1.348-1.638m-9.878-9.878L3 3m6.518 6.518 1.638 1.348a2.048 2.048 0 0 0 3.232 0l5.653-4.655" />
      </svg>
    </div>

    <h1 class="gradient-text" style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; letter-spacing: -0.02em; animation: slideUp var(--duration-slow) var(--ease-out) 0.1s both;">
      站点维护中
    </h1>
    <p class="text-[var(--text-muted)] text-[0.9375rem] max-w-[400px] text-center" style="animation: slideUp var(--duration-slow) var(--ease-out) 0.2s both;">
      站点正在进行维护，请稍后再来访问。维护完成后将自动恢复访问。
    </p>

    {isAdmin && (
      <a
        href="/admin?tab=settings"
        class="mt-4 px-5 py-2.5 rounded-[var(--radius-md)] bg-[var(--accent-color)] text-[var(--bg-primary)] font-medium inline-flex items-center gap-2 hover:bg-[var(--accent-hover)] active:scale-[0.97] transition-all duration-[var(--duration-fast)]"
        style="animation: slideUp var(--duration-slow) var(--ease-out) 0.3s both;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.56.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.893.149c-.425.07-.765.383-.93.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.397.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.273-.806.108-1.204-.165-.397-.505-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.107-1.204l-.527-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
        </svg>
        进入管理后台关闭维护模式
      </a>
    )}

    {!isAdmin && (
      <a
        href="/login"
        class="mt-2 text-sm text-[var(--text-muted)] hover:text-[var(--accent-color)] transition-colors duration-[var(--duration-fast)]"
        style="animation: slideUp var(--duration-slow) var(--ease-out) 0.3s both;"
      >
        管理员登录 →
      </a>
    )}
  </div>
</BaseLayout>
