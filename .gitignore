# Environment files (contain secrets!)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/

# Node / Frontend
node_modules/
frontend/node_modules/
frontend/.astro/
frontend/dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docker volumes (local dev data)
postgres_data/
redis_data/
minio_data/

# Alembic
*.pyc

# Logs
*.log