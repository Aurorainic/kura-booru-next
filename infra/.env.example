# =============================================================================
# Kura Booru V2 — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.
# =============================================================================

# === Application ===
APP_URL=https://kura.example.com
# Full public URL of the site (no trailing slash).

# === Secret Key ===
SECRET_KEY=change-me-to-a-random-string-in-production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"

# === S3 Storage (any S3-compatible service) ===
# Works with Cloudflare R2, MinIO, AWS S3, Wasabi, etc.
# Just change the endpoint and credentials below.

# Internal endpoint used by backend for S3 API operations (uploads, etc.)
# R2:       https://<account-id>.r2.cloudflarestorage.com
# MinIO:    http://minio:9000  (or http://localhost:9000 from host)
# AWS S3:   https://s3.<region>.amazonaws.com
S3_ENDPOINT=http://minio:9000

# Public URL prefix for serving images to browsers.
# Caddy /i/* proxies to S3, so this must include /i/<bucket>.
# Pattern: <APP_URL>/i/<S3_BUCKET_NAME>
S3_EXTERNAL_URL=https://kura.example.com/i/kura-booru

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# S3 credentials. R2: API token key/secret. MinIO: root credentials. AWS: IAM key.

S3_BUCKET_NAME=kura-booru
S3_REGION=us-east-1
# R2 uses "auto". MinIO default is "us-east-1". AWS S3 uses the actual region.

# Caddy S3 proxy upstream — used by Caddyfile as {$S3_PROXY_UPSTREAM}
# This is the S3 endpoint Caddy proxies /i/* to.
# R2:       https://<account-id>.r2.cloudflarestorage.com
# MinIO:    http://localhost:9000
# AWS S3:   https://s3.<region>.amazonaws.com
S3_PROXY_UPSTREAM=http://localhost:9000

# === Database ===
DATABASE_URL=postgresql+asyncpg://kura:kura_password@postgres:5432/kurabooru
# Asyncpg driver URL. Matches docker-compose PostgreSQL defaults.

# === Redis ===
REDIS_URL=redis://redis:6379/0
# ARQ task queue + app cache. Caddy Souin uses its own Redis config.

# === Telegram Bot ===
BOT_TOKEN=123456:ABC-xxx-xxx
BOT_WEBHOOK_URL=https://kura.example.com/bot/webhook
BOT_WEBHOOK_SECRET=your-webhook-secret-token
BOT_ADMIN_IDS=12345,67890

# === Image Processing ===
MAX_IMAGE_SIZE=6291456
THUMB_SIZE=150x150
PREVIEW_SIZE=850x850

# === gallery-dl Authentication ===
PIXIV_REFRESH_TOKEN=your-pixiv-refresh-token
PIXIV_PHPSESSID=your-pixiv-phpsessid-cookie
# TWITTER_AUTH_TOKEN=your-twitter-auth-token
# TWITTER_CT0=your-twitter-ct0-cookie

# === Frontend ===
PUBLIC_API_URL=https://kura.example.com/api

# === PostgreSQL (for docker-compose only) ===
POSTGRES_USER=kura
POSTGRES_PASSWORD=kura_password