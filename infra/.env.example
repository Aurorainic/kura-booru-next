# =============================================================================
# Kura Booru Next — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.
#
# Usage:
#   cp infra/.env.example infra/.env
#   # Edit infra/.env with your actual values
#   cd infra && docker compose up -d          # Production
#   cd infra && docker compose -f docker-compose.dev.yml up  # Development
#
# Validation:
#   ./scripts/validate-env.sh prod   # Strict production validation
#   ./scripts/validate-env.sh dev    # Lenient development validation
# =============================================================================

# === Application ===
APP_URL=https://kura.example.com
# Full public URL of the site (no trailing slash).

APP_DOMAIN=kura.example.com
# Domain name for Caddy virtual host and frontend allowedHosts.

# === Secret Key ===
SECRET_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED in production — no default.

# === Admin Auth ===
ADMIN_USERNAME=admin
# Username for the initial admin account (created on first startup).

ADMIN_PASSWORD=
# Password for the initial admin account. If empty, a random password is
# generated and printed to the server logs on first startup.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(16))"
# REQUIRED in production.

ADMIN_SESSION_MAX_AGE=604800
# Session cookie lifetime in seconds. Default: 7 days (604800).

BACKEND_API_KEY=
# Shared secret for trusted internal callers (Telegram bot, future web ingestion).
# When set, POST /api/tasks/ and POST /api/rebuild/ require this as X-Api-Key header.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# REQUIRED in production.

# === S3 Storage (any S3-compatible service) ===
# Works with Cloudflare R2, MinIO, AWS S3, Wasabi, etc.
# Just change the endpoint and credentials below.
# Images are served DIRECTLY from S3/CDN — NOT via Caddy proxy.

# Internal endpoint used by backend for S3 API operations (uploads, etc.)
# R2:       https://<account-id>.r2.cloudflarestorage.com
# MinIO:    http://minio:9000  (or http://localhost:9000 from host)
# AWS S3:   https://s3.<region>.amazonaws.com
S3_ENDPOINT=http://minio:9000

# Public URL prefix for serving images to browsers (direct S3/CDN).
# Backend uses this for public_url(). Frontend uses PUBLIC_S3_EXTERNAL_URL.
# R2 CDN:   https://images.your-domain.com
# MinIO:    http://localhost:9000/kura-booru
# AWS S3:   https://<bucket>.s3.<region>.amazonaws.com
S3_EXTERNAL_URL=https://images.kura.example.com

# S3 credentials. R2: API token key/secret. MinIO: root credentials. AWS: IAM key.
S3_ACCESS_KEY=
S3_SECRET_KEY=

S3_BUCKET_NAME=kura-booru
S3_REGION=auto
# R2 uses "auto". MinIO default is "us-east-1". AWS S3 uses the actual region.

# === Database ===
DATABASE_URL=postgresql+asyncpg://kura:<password>@postgres:5432/kurabooru
# Asyncpg driver URL. Matches docker-compose PostgreSQL defaults.
# Replace <password> with POSTGRES_PASSWORD value.

# PostgreSQL credentials for docker-compose
POSTGRES_USER=kura
POSTGRES_PASSWORD=
# REQUIRED in production — no default.

POSTGRES_DB=kurabooru

# === Redis ===
REDIS_URL=redis://redis:6379/0
# ARQ task queue + app cache.

REDIS_PASSWORD=
# Redis authentication. NOTE: the backend/bot connect via REDIS_URL only.
# If you set a password, include it in REDIS_URL: redis://:password@redis:6379/0
# This variable alone has no effect unless REDIS_URL references it.

# === Telegram Bot ===
BOT_TOKEN=
# REQUIRED — get from @BotFather on Telegram.

BOT_WEBHOOK_URL=https://kura.example.com/bot/webhook
# Public URL for Telegram webhook (must be accessible from Telegram servers).

BOT_WEBHOOK_SECRET=
# Secret token for webhook verification.

BOT_ADMIN_IDS=12345,67890
# Comma-separated Telegram user IDs allowed to use the bot.

BOT_PORT=8080
# Bot aiohttp server port.

FRONTEND_URL=https://kura.example.com
# Public frontend URL for bot messages with links.

# === Image Processing ===
MAX_IMAGE_SIZE=0
# 0 = no limit. Set to a byte value (e.g. 20971520 for 20 MB) to enforce a cap.

THUMB_SIZE=400x400
PREVIEW_SIZE=1200x1200
# Thumbnail and preview dimensions (WxH).

# === gallery-dl Authentication ===
PIXIV_REFRESH_TOKEN=
# Pixiv refresh token for downloading Pixiv images.

PIXIV_PHPSESSID=
# Pixiv PHPSESSID cookie for metadata extraction.

# TWITTER_AUTH_TOKEN=your-twitter-auth-token
# TWITTER_CT0=your-twitter-ct0-cookie
# Twitter/X authentication (for future Twitter extractor support).

# === AI Tag Processing ===
# When ENABLE_AI_TAG_PROCESSING=true, new images are auto-classified by an
# OpenAI-compatible API into 5 categories + Chinese translation + Danbooru tags.
ENABLE_AI_TAG_PROCESSING=false
# Set to "true" to enable. Default: false.

AI_PROVIDER_API_KEY=
# API key for the OpenAI-compatible provider. REQUIRED if AI is enabled.

AI_PROVIDER_ENDPOINT=
# Base URL of the OpenAI-compatible API (e.g. https://api.openai.com/v1).
# REQUIRED if AI is enabled.

AI_PROVIDER_MODEL=
# Model name (e.g. gpt-4o-mini). REQUIRED if AI is enabled.

# === Frontend ===
PUBLIC_GIT_TAG=v0.4.1
# Git version tag shown in the frontend footer. Update this to match your release.
# Dev mode: Astro dev server reads this from .env at runtime.
# Production: Set during Docker build with --build-arg PUBLIC_GIT_TAG=<version>.

PUBLIC_API_URL=https://your-domain.com/api
# Public API URL for client-side requests (browser → API).

PUBLIC_S3_EXTERNAL_URL=https://images.your-domain.com
# Public URL prefix for serving images directly from S3/CDN to browsers.
# Do NOT include /i/ — images are served directly from S3/CDN, not via Caddy proxy.
# The frontend appends /{key} to this base URL (e.g. https://images.your-domain.com/originals/...)
# Examples:
#   Cloudflare R2:  https://images.your-domain.com
#   MinIO (dev):    http://localhost:9000/kura-booru

INTERNAL_API_URL=http://backend:8000/api
# Internal API URL for SSR (Astro server → backend within Docker network).

# === Caddy (host-side env vars) ===
# These are read by Caddyfile using {$VAR} syntax.

S3_PROXY_UPSTREAM=https://images.kura.example.com
# Upstream URL for Caddy /i/* image proxy. Only used if serving images via
# Caddy reverse proxy instead of direct S3/CDN. Leave empty if not needed.

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

BOT_HOST=127.0.0.1
BOT_PORT=8080

FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=4321

# === Database Migration (for migrate-db.sh) ===
DEV_PG_CONTAINER=kura-postgres-dev
# Name of the development PostgreSQL container (used by migrate-db.sh).

PROD_DATABASE_URL=
# Production database URL for importing dumps.
# Example: postgresql://user:password@prod-host:5432/kurabooru
