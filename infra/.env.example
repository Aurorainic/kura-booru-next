# =============================================================================
# Kura Booru Next — Environment Variables
# =============================================================================
# 4-container setup: Nuxt/Nitro (SSR+API+Bot), Python sidecar, PostgreSQL, Redis
# Copy this file to the project root as .env and fill in real values.
# .env is git-ignored — never commit secrets.
#
# Usage:
#   cp infra/.env.example .env
#   # Edit .env with your actual values
#   cd infra && docker compose up -d --force-recreate          # Production
#   cd infra && docker compose up -d  # Development
#
# Validation:
#   cd infra && ./scripts/validate-env.sh prod   # Strict production validation
#   cd infra && ./scripts/validate-env.sh dev    # Lenient development validation
# =============================================================================

# === Application ===
SITE_URL=https://kura.example.com
KURA_VERSION=v0.7.0

# === Secret Key ===
SESSION_SECRET=
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# REQUIRED in production

SECRET_KEY=
# Legacy key still used by some modules. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# REQUIRED in production

# === Admin Auth ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
BACKEND_API_KEY=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# REQUIRED in production

# === S3 Storage (any S3-compatible service) ===
S3_ENDPOINT=http://minio:9000
S3_EXTERNAL_URL=https://images.kura.example.com
# Public URL for serving images. Leave empty in Standalone mode to use /i/ proxy.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=kura-booru
S3_REGION=auto

# === Database ===
DATABASE_URL=postgres://kura:kura_password@postgres:5432/kurabooru
# postgres-js format (no +asyncpg). Used by Drizzle ORM.
POSTGRES_USER=kura
POSTGRES_PASSWORD=kura_password
POSTGRES_DB=kurabooru

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Telegram Bot ===
BOT_TOKEN=
# REQUIRED — get from @BotFather on Telegram.

BOT_WEBHOOK_SECRET=
# Secret token for webhook verification.

BOT_ADMIN_IDS=12345,67890
# Comma-separated Telegram user IDs allowed to use the bot.

# === Image Processing ===
MAX_IMAGE_SIZE=0
THUMB_SIZE=400x400
PREVIEW_SIZE=1200x1200

# === gallery-dl Authentication ===
PIXIV_REFRESH_TOKEN=
PIXIV_PHPSESSID=

# === AI Tag Processing ===
ENABLE_AI_TAG_PROCESSING=false
AI_PROVIDER_API_KEY=
AI_PROVIDER_ENDPOINT=
AI_PROVIDER_MODEL=

# === Internal URLs (defaults work for Docker Compose) ===
INTERNAL_API_URL=http://127.0.0.1:3000/api
# In-process by default. Change only for external API deployments.

# === Reverse Proxy (optional, on host) ===
NUXT_HOST=127.0.0.1
NUXT_PORT=3000
