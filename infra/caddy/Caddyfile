{$APP_DOMAIN:kura-booru.lainns.xyz} {
    encode zstd gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    # API routes — NO CACHE, proxy to FastAPI backend
    handle /api/* {
        reverse_proxy {$BACKEND_HOST:127.0.0.1}:{$BACKEND_PORT:8000} {
            fail_duration 30s
            max_fails 3
        }
        request_body {
            max_size 50MB
        }
    }

    # Telegram Bot webhook — NO CACHE, proxy to bot container
    handle /bot/webhook {
        reverse_proxy {$BOT_HOST:127.0.0.1}:{$BOT_PORT:8080}
    }

    # Frontend SSR (Astro) — default route
    handle {
        reverse_proxy {$FRONTEND_HOST:127.0.0.1}:{$FRONTEND_PORT:4321}
    }

    # Cache-Control: immutable for hashed assets
    @hashedAssets {
        path *.js *.css *.woff2 *.woff *.png *.jpg *.svg *.ico *.webp *.avif
    }
    header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

    log {
        output file /var/log/caddy/kura-booru-access.log
    }
}
